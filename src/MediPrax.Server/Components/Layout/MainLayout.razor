@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-layout">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <img src="/images/logo-mediprax-icon.svg" alt="MediPrax" class="brand-icon" />
            <div class="brand-text">
                <span class="brand-name"><span class="brand-medi">Medi</span>Prax</span>
                <span class="brand-tagline">PRAXISVERWALTUNG</span>
            </div>
        </div>

        <GlobalSearch />

        <div class="sidebar-section">
            <span class="section-label">Navigation</span>
            <ul class="nav-menu">
                <li>
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        Start
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/patienten" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        Patienten
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/termine" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Termine
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/therapie" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
                        Therapie
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/abrechnung" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                        Abrechnung
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/wartezimmer" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Wartezimmer
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/warteliste" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="15" y2="16"/></svg>
                        Warteliste
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/berichte" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                        Berichte
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/wiedervorlagen" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        Wiedervorlagen
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="sidebar-section">
            <span class="section-label">Telematik</span>
            <ul class="nav-menu">
                <li>
                    <NavLink href="/telematik/egk" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        eGK einlesen
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/telematik/erezept" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/></svg>
                        E-Rezept
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/telematik/kim" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                        KIM-Postfach
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/telematik/status" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        TI-Status
                    </NavLink>
                </li>
            </ul>
        </div>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="sidebar-section">
                    <span class="section-label">Verwaltung</span>
                    <ul class="nav-menu">
                        <li>
                            <NavLink href="/verwaltung/benutzer" class="nav-item">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15c-4 0-7 2-7 4v1h14v-1c0-2-3-4-7-4z"/><circle cx="12" cy="8" r="4"/><path d="M19 8v6M22 11h-6"/></svg>
                                Benutzer
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/verwaltung/import" class="nav-item">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                Datenimport
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/verwaltung/icd10" class="nav-item">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
                                ICD-10 Katalog
                            </NavLink>
                        </li>
                        <li>
                            <NavLink href="/verwaltung/audit-log" class="nav-item">
                                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                Audit-Log
                            </NavLink>
                        </li>
                    </ul>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="user-info">
                        <div class="user-avatar">@context.User.Identity?.Name?[..1]</div>
                        <div class="user-details">
                            <span class="user-name">@context.User.Identity?.Name</span>
                            <span class="user-role">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </div>
                    </div>
                    <div class="user-actions">
                        <a href="/konto/passwort" class="user-action-link">Passwort</a>
                        <button class="user-action-link" @onclick="ToggleTheme">@(isDark ? "☀" : "☾")</button>
                        <a href="/api/logout" class="logout-btn">Abmelden</a>
                    </div>
                </Authorized>
            </AuthorizeView>
            <span class="footer-text">Neuropsychiatricum Bremen</span>
        </div>
    </nav>

    <div class="main-wrapper">
        <main class="main-content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2717;</span>
</div>

@code {
    private bool isDark;

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{(isDark ? "dark" : "light")}')");
    }
}
