@inherits LayoutComponentBase

<div class="app-layout">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">M</div>
            <span>MediPrax</span>
        </div>

        <div class="sidebar-section">
            <span class="section-label">Navigation</span>
            <ul class="nav-menu">
                <li>
                    <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        Start
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/patienten" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                        Patienten
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/termine" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Termine
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/wartezimmer" class="nav-item">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Wartezimmer
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <AuthorizeView>
                <Authorized>
                    <div class="user-info">
                        <div class="user-avatar">@context.User.Identity?.Name?[..1]</div>
                        <div class="user-details">
                            <span class="user-name">@context.User.Identity?.Name</span>
                            <span class="user-role">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </div>
                    </div>
                    <button class="logout-btn" @onclick="Logout">Abmelden</button>
                </Authorized>
            </AuthorizeView>
            <span class="footer-text">Neuropsychiatricum Bremen</span>
        </div>
    </nav>

    <div class="main-wrapper">
        <main class="main-content">
            @Body
        </main>
    </div>
</div>

@inject NavigationManager Navigation

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2717;</span>
</div>

@code {
    private async Task Logout()
    {
        var http = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
        await http.PostAsync("/api/logout", null);
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
