@page "/handbuch"
@page "/handbuch/{*Path}"
@attribute [Authorize]
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Benutzerhandbuch</PageTitle>

<div class="docs-container">
    <iframe id="docs-frame"
            src="@GetDocsUrl()"
            class="docs-iframe"
            @ref="iframeRef">
    </iframe>
</div>

<style>
    /* Break out of the .main-content padding and max-width constraints */
    .docs-container {
        margin: -2rem -2.5rem;
        height: calc(100vh);
        max-width: none !important;
        width: calc(100% + 5rem);
    }

    .docs-iframe {
        width: 100%;
        height: 100%;
        border: none;
        background: var(--color-surface, #ffffff);
    }

    /* Override parent constraints when this page is active */
    :global(.main-content:has(.docs-container)) {
        max-width: none !important;
        padding: 0 !important;
    }
</style>

@code {
    [Parameter] public string? Path { get; set; }

    private ElementReference iframeRef;

    private string GetDocsUrl()
    {
        if (string.IsNullOrEmpty(Path))
            return "/docs/";
        return $"/docs/{Path}/";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", """
                var frame = document.getElementById('docs-frame');
                if (frame) {
                    frame.onload = function() {
                        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
                        frame.contentWindow.postMessage({ type: 'theme-change', dark: dark }, '*');
                    };
                }
            """);
        }
    }
}
