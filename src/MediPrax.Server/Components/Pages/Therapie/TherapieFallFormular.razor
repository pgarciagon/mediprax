@page "/therapie/neu"
@page "/therapie/{Id:guid}/bearbeiten"
@attribute [Authorize(Policy = "Klinisch")]
@inject ITherapyCaseService TherapyCaseService
@inject IPatientService PatientService
@inject IUserService UserService
@inject IIcd10CodeService Icd10Service
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(isEdit ? "Therapiefall bearbeiten" : "Neuer Therapiefall")</PageTitle>

<div class="page-header">
    <h1>@(isEdit ? "Therapiefall bearbeiten" : "Neuer Therapiefall")</h1>
</div>

@if (loading)
{
    <p>Laden...</p>
}
else
{
    <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="therapyCaseForm">
        <DataAnnotationsValidator />

        <fieldset>
            <legend>Patient &amp; Therapeut</legend>

            <div class="form-row">
                <div class="form-group">
                    <label>Patient *</label>
                    <InputSelect @bind-Value="form.PatientId" class="form-control">
                        <option value="@Guid.Empty">— Patient wählen —</option>
                        @if (patients is not null)
                        {
                            @foreach (var p in patients)
                            {
                                <option value="@p.Id">@p.FullName (@p.DateOfBirth.ToString("dd.MM.yyyy"))</option>
                            }
                        }
                    </InputSelect>
                </div>
                <div class="form-group">
                    <label>Therapeut *</label>
                    <InputSelect @bind-Value="form.TherapistId" class="form-control">
                        <option value="@Guid.Empty">— Therapeut wählen —</option>
                        @if (therapists is not null)
                        {
                            @foreach (var t in therapists)
                            {
                                <option value="@t.Id">@t.FullName</option>
                            }
                        }
                    </InputSelect>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Therapieverfahren</legend>

            <div class="form-row">
                <div class="form-group">
                    <label>Verfahren *</label>
                    <InputSelect @bind-Value="form.TherapyType" @bind-Value:after="OnTherapyTypeChanged" class="form-control">
                        <option value="PsychotherapeutischeSprechstunde">Psychotherapeutische Sprechstunde</option>
                        <option value="Probatorik">Probatorik</option>
                        <option value="Akutbehandlung">Akutbehandlung</option>
                        <option value="KurzzeittherapieKZT1">Kurzzeittherapie (KZT1)</option>
                        <option value="KurzzeittherapieKZT2">Kurzzeittherapie (KZT2)</option>
                        <option value="LangzeittherapieVT">Langzeittherapie VT</option>
                        <option value="LangzeittherapieTP">Langzeittherapie TP</option>
                        <option value="LangzeittherapieAP">Langzeittherapie AP</option>
                        <option value="LangzeittherapieST">Langzeittherapie ST</option>
                        <option value="NeuropsychologischeTherapie">Neuropsychologische Therapie</option>
                    </InputSelect>
                </div>
                <div class="form-group">
                    <label>Startdatum *</label>
                    <InputDate @bind-Value="form.StartDate" class="form-control" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Bewilligte Sitzungen</label>
                    <InputNumber @bind-Value="form.ApprovedSessions" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Sitzungsdauer (Min.)</label>
                    <InputNumber @bind-Value="form.SessionDurationMinutes" class="form-control" />
                </div>
                <div class="form-group" style="flex:0.5;align-self:end;padding-bottom:0.4rem;">
                    <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;">
                        <InputCheckbox @bind-Value="form.IsGroupTherapy" />
                        Gruppentherapie
                    </label>
                </div>
            </div>
        </fieldset>

        @if (isEdit)
        {
            <fieldset>
                <legend>Status &amp; Genehmigung</legend>

                <div class="form-row">
                    <div class="form-group">
                        <label>Status</label>
                        <InputSelect @bind-Value="form.Status" class="form-control">
                            <option value="SprechstundePhase">Sprechstunde</option>
                            <option value="ProbatorikPhase">Probatorik</option>
                            <option value="AntragGestellt">Antrag gestellt</option>
                            <option value="InGutachterverfahren">Gutachterverfahren</option>
                            <option value="Bewilligt">Bewilligt</option>
                            <option value="Abgelehnt">Abgelehnt</option>
                            <option value="InBehandlung">In Behandlung</option>
                            <option value="VerlaengerungBeantragt">Verlängerung beantragt</option>
                            <option value="Abgeschlossen">Abgeschlossen</option>
                            <option value="Abgebrochen">Abgebrochen</option>
                        </InputSelect>
                    </div>
                    <div class="form-group">
                        <label>Enddatum</label>
                        <InputDate @bind-Value="form.EndDate" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Kassengenehmigung Ref.</label>
                        <InputText @bind-Value="form.InsuranceApprovalRef" class="form-control" placeholder="Aktenzeichen" />
                    </div>
                </div>
            </fieldset>
        }

        <fieldset>
            <legend>Diagnosen (ICD-10)</legend>

            <div style="position:relative;">
                <label>Code oder Beschreibung suchen</label>
                <div style="display:flex;gap:0;">
                    <input type="text"
                           @bind="icdSearchTerm"
                           @bind:event="oninput"
                           @bind:after="SearchIcd"
                           @onfocus="OnIcdFocus"
                           placeholder="z.B. F32 oder Depression..."
                           class="form-control"
                           style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                    <button type="button"
                            class="btn btn-secondary"
                            style="border-top-left-radius:0;border-bottom-left-radius:0;padding:0 0.75rem;min-width:2.5rem;font-size:0.8rem;"
                            @onclick="ToggleIcdDropdown">
                        ▼
                    </button>
                </div>
                @if (showIcdDropdown && icdDropdownItems.Count > 0)
                {
                    <div class="search-dropdown" style="max-height:250px;overflow-y:auto;">
                        @foreach (var entry in icdDropdownItems)
                        {
                            <div class="search-item" @onclick="() => AddIcdFromSearch(entry)">
                                <span class="icd-code">@entry.Code</span>
                                <span class="icd-desc">@entry.Description</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (form.Diagnoses.Count > 0)
            {
                <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.75rem;">
                    @foreach (var d in form.Diagnoses)
                    {
                        var desc = icdDescriptions.GetValueOrDefault(d, "");
                        <span style="display:inline-flex;align-items:center;gap:0.5rem;background:#e0f2fe;border:1px solid #7dd3fc;border-radius:6px;padding:0.35rem 0.6rem;font-size:0.85rem;">
                            <strong>@d</strong> @desc
                            <button type="button" @onclick="() => RemoveDiagnosis(d)"
                                    style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:#64748b;padding:0 0.2rem;line-height:1;">&times;</button>
                        </span>
                    }
                </div>
            }
            else
            {
                <span class="no-codes" style="margin-top:0.5rem;display:block;">Keine Diagnosen hinzugefügt.</span>
            }
        </fieldset>

        <fieldset>
            <legend>Notizen</legend>
            <div class="form-group">
                <InputTextArea @bind-Value="form.Notes" class="form-control" rows="3" placeholder="Interne Notizen zum Therapiefall..." />
            </div>
        </fieldset>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" disabled="@saving">
                @(saving ? "Speichern..." : "Speichern")
            </button>
            <a href="@(isEdit ? $"/therapie/{Id}" : "/therapie")" class="btn btn-secondary">Abbrechen</a>
        </div>
    </EditForm>
}

<style>
    fieldset {
        margin-bottom: 1.5rem;
        padding: 1.25rem;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }
    .form-row:has(> :nth-child(3)) {
        grid-template-columns: 1fr 1fr auto;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .form-group label {
        font-size: 0.85rem;
        font-weight: 500;
        color: #374151;
    }
</style>

@code {
    [Parameter] public Guid? Id { get; set; }

    private TherapyCaseFormModel form = new();
    private bool isEdit => Id.HasValue;
    private bool loading = true;
    private bool saving;
    private string? errorMessage;
    private string icdSearchTerm = string.Empty;
    private bool showIcdDropdown;
    private IReadOnlyList<Icd10CodeDto> icdDropdownItems = [];
    private Dictionary<string, string> icdDescriptions = new();
    private IReadOnlyList<PatientListItemDto>? patients;
    private IReadOnlyList<UserListItemDto>? therapists;

    protected override async Task OnInitializedAsync()
    {
        patients = (await PatientService.SearchAsync(new PatientSearchDto { PageSize = 500 })).Items;
        therapists = await UserService.GetAllAsync();

        if (isEdit)
        {
            var tc = await TherapyCaseService.GetByIdAsync(Id!.Value);
            if (tc is null)
            {
                Navigation.NavigateTo("/therapie");
                return;
            }
            form = new TherapyCaseFormModel
            {
                PatientId = tc.PatientId,
                TherapistId = tc.TherapistId,
                TherapyType = tc.TherapyType.ToString(),
                StartDate = tc.StartDate,
                ApprovedSessions = tc.ApprovedSessions,
                SessionDurationMinutes = tc.SessionDurationMinutes,
                IsGroupTherapy = tc.IsGroupTherapy,
                Diagnoses = tc.Diagnoses.ToList(),
                Notes = tc.Notes,
                Status = tc.Status.ToString(),
                EndDate = tc.EndDate,
                InsuranceApprovalRef = tc.Notes
            };
            foreach (var c in form.Diagnoses)
            {
                var desc = await Icd10Service.GetDescriptionAsync(c);
                if (desc is not null) icdDescriptions[c] = desc;
            }
        }
        loading = false;
    }

    private void OnTherapyTypeChanged()
    {
        if (Enum.TryParse<TherapyType>(form.TherapyType, out var tt))
        {
            var info = MediPrax.Application.Services.TherapyContingentRules.GetContingentInfo(tt);
            form.ApprovedSessions = info.InitialSessions;
            form.SessionDurationMinutes = info.SessionDurationMinutes;
        }
    }

    private async Task OnIcdFocus()
    {
        if (!showIcdDropdown)
            await ToggleIcdDropdown();
    }

    private async Task SearchIcd()
    {
        if (string.IsNullOrWhiteSpace(icdSearchTerm))
        {
            showIcdDropdown = false;
            icdDropdownItems = [];
        }
        else
        {
            icdDropdownItems = await Icd10Service.SearchAsync(icdSearchTerm);
            showIcdDropdown = icdDropdownItems.Count > 0;
        }
    }

    private async Task ToggleIcdDropdown()
    {
        if (showIcdDropdown)
        {
            showIcdDropdown = false;
            return;
        }
        if (string.IsNullOrWhiteSpace(icdSearchTerm))
        {
            icdDropdownItems = await Icd10Service.GetAllAsync();
        }
        else
        {
            icdDropdownItems = await Icd10Service.SearchAsync(icdSearchTerm);
        }
        showIcdDropdown = icdDropdownItems.Count > 0;
    }

    private void AddIcdFromSearch(Icd10CodeDto entry)
    {
        if (!form.Diagnoses.Contains(entry.Code))
        {
            form.Diagnoses.Add(entry.Code);
            icdDescriptions[entry.Code] = entry.Description;
        }
        icdSearchTerm = string.Empty;
        icdDropdownItems = [];
        showIcdDropdown = false;
    }

    private void RemoveDiagnosis(string d) => form.Diagnoses.Remove(d);

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        try
        {
            if (!Enum.TryParse<TherapyType>(form.TherapyType, out var therapyType))
            {
                errorMessage = "Ungültiger Therapietyp.";
                saving = false;
                return;
            }

            if (isEdit)
            {
                Enum.TryParse<TherapyCaseStatus>(form.Status, out var status);
                await TherapyCaseService.UpdateAsync(new UpdateTherapyCaseDto
                {
                    Id = Id!.Value,
                    PatientId = form.PatientId,
                    TherapistId = form.TherapistId,
                    TherapyType = therapyType,
                    StartDate = form.StartDate,
                    ApprovedSessions = form.ApprovedSessions,
                    SessionDurationMinutes = form.SessionDurationMinutes,
                    IsGroupTherapy = form.IsGroupTherapy,
                    Diagnoses = form.Diagnoses,
                    Notes = form.Notes,
                    Status = status,
                    EndDate = form.EndDate,
                    InsuranceApprovalRef = form.InsuranceApprovalRef
                });
                Navigation.NavigateTo($"/therapie/{Id}");
            }
            else
            {
                var created = await TherapyCaseService.CreateAsync(new CreateTherapyCaseDto
                {
                    PatientId = form.PatientId,
                    TherapistId = form.TherapistId,
                    TherapyType = therapyType,
                    StartDate = form.StartDate,
                    ApprovedSessions = form.ApprovedSessions,
                    SessionDurationMinutes = form.SessionDurationMinutes,
                    IsGroupTherapy = form.IsGroupTherapy,
                    Diagnoses = form.Diagnoses,
                    Notes = form.Notes
                });
                Navigation.NavigateTo($"/therapie/{created.Id}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            saving = false;
        }
    }

    private class TherapyCaseFormModel
    {
        public Guid PatientId { get; set; }
        public Guid TherapistId { get; set; }
        public string TherapyType { get; set; } = "PsychotherapeutischeSprechstunde";
        public DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public int ApprovedSessions { get; set; } = 6;
        public int SessionDurationMinutes { get; set; } = 25;
        public bool IsGroupTherapy { get; set; }
        public List<string> Diagnoses { get; set; } = [];
        public string? Notes { get; set; }
        public string Status { get; set; } = "SprechstundePhase";
        public DateOnly? EndDate { get; set; }
        public string? InsuranceApprovalRef { get; set; }
    }
}
