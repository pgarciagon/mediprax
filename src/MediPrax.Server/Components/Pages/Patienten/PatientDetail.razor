@page "/patienten/{Id:guid}"
@attribute [Authorize]
@inject IPatientService PatientService
@inject IEncounterService EncounterService
@inject IArztbriefService ArztbriefService
@inject IAuditService AuditService
@inject IMedicationService MedicationService
@inject IRecallService RecallService
@inject IPsychometricTestService PsychometricTestService
@inject ISeizureDiaryService SeizureDiaryService
@inject IHeadacheDiaryService HeadacheDiaryService
@inject IMsDocumentationService MsDocService
@inject IParkinsonDocumentationService ParkinsonService
@inject ISuicidalityAssessmentService SuicidalityService
@inject ILabResultService LabResultService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Patient — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <div class="page-header">
        <h1>@patient.FullName</h1>
        <div class="header-actions">
            <a href="/patienten/@Id/formulare" class="btn btn-secondary">Formulare</a>
            <a href="/patienten/@Id/bearbeiten" class="btn btn-primary">Bearbeiten</a>
            <button @onclick="HandleDelete" class="btn btn-danger">Löschen</button>
        </div>
    </div>

    <div class="detail-grid">
        <section class="detail-card">
            <h3>Persönliche Daten</h3>
            <dl>
                <dt>Name</dt>
                <dd>@patient.FirstName @patient.LastName</dd>

                <dt>Geburtsdatum</dt>
                <dd>@patient.DateOfBirth.ToString("dd.MM.yyyy")</dd>

                <dt>Geschlecht</dt>
                <dd>@(patient.Gender ?? "—")</dd>
            </dl>
        </section>

        <section class="detail-card">
            <h3>Versicherung</h3>
            <dl>
                <dt>Art</dt>
                <dd>@patient.InsuranceDisplay</dd>

                <dt>Krankenkasse</dt>
                <dd>@(patient.InsuranceProvider ?? "—")</dd>

                <dt>Versichertennr.</dt>
                <dd>@(patient.InsuranceNumber ?? "—")</dd>

                <dt>KVNR</dt>
                <dd>@(patient.Kvnr ?? "—")</dd>
            </dl>
        </section>

        <section class="detail-card">
            <h3>Kontakt & Adresse</h3>
            <dl>
                <dt>Telefon</dt>
                <dd>@(patient.Phone ?? "—")</dd>

                <dt>E-Mail</dt>
                <dd>@(patient.Email ?? "—")</dd>

                <dt>Adresse</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(patient.Street))
                    {
                        @patient.Street<br />
                    }
                    @if (!string.IsNullOrEmpty(patient.PostalCode) || !string.IsNullOrEmpty(patient.City))
                    {
                        @($"{patient.PostalCode} {patient.City}".Trim())
                    }
                    else
                    {
                        <text>—</text>
                    }
                </dd>
            </dl>
        </section>
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Konsultationen</h2>
            <a href="/patienten/@Id/dokumentation/neu" class="btn btn-sm btn-primary">+ Neue Konsultation</a>
        </div>

        @if (encounters is null)
        {
            <p>Laden...</p>
        }
        else if (encounters.Count == 0)
        {
            <div class="empty-encounters">Noch keine Dokumentation vorhanden.</div>
        }
        else
        {
            <div class="encounter-list">
                @foreach (var enc in encounters)
                {
                    <a href="/dokumentation/@enc.Id/bearbeiten" class="encounter-item">
                        <div class="enc-date">
                            <span class="enc-day">@enc.EncounterDate.ToString("dd")</span>
                            <span class="enc-month">@enc.EncounterDate.ToString("MMM yy", new System.Globalization.CultureInfo("de-DE"))</span>
                        </div>
                        <div class="enc-details">
                            <span class="enc-doctor">@enc.DoctorName</span>
                            <span class="enc-codes">
                                @if (enc.Icd10Codes.Count > 0)
                                {
                                    @string.Join(", ", enc.Icd10Codes)
                                }
                                else
                                {
                                    <text>Keine Diagnosen</text>
                                }
                            </span>
                        </div>
                        <div class="enc-meta">
                            @if (enc.DurationMinutes.HasValue)
                            {
                                <span>@enc.DurationMinutes Min.</span>
                            }
                            <span class="enc-status status-@enc.Status.ToString().ToLower()">@enc.Status</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Arztbriefe</h2>
            <a href="/patienten/@Id/arztbrief/neu" class="btn btn-sm btn-primary">+ Neuer Arztbrief</a>
        </div>

        @if (arztbriefe is null || arztbriefe.Count == 0)
        {
            <div class="empty-encounters">Noch keine Arztbriefe vorhanden.</div>
        }
        else
        {
            <div class="encounter-list">
                @foreach (var brief in arztbriefe)
                {
                    <a href="/arztbrief/@brief.Id" class="encounter-item" style="display:flex;align-items:center;">
                        <div class="enc-date">
                            <svg style="width:20px;height:20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div class="enc-details" style="flex:1">
                            <span class="enc-doctor">@brief.Title</span>
                            <span class="enc-codes">@brief.CreatedAt.ToString("dd.MM.yyyy HH:mm") @(!string.IsNullOrEmpty(brief.RecipientName) ? $"→ {brief.RecipientName}" : "")</span>
                        </div>
                        <div class="enc-meta" style="display:flex;gap:0.4rem;align-items:center;">
                            <span class="enc-status status-@brief.StatusColor">@brief.StatusDisplay</span>
                            @if (brief.HasPdf)
                            {
                                <span class="btn btn-sm btn-secondary" @onclick:stopPropagation="true" @onclick="() => { }">
                                    <a href="/dokumente/@brief.Id/pdf" target="_blank" style="color:inherit;text-decoration:none">PDF</a>
                                </span>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Medikamentenplan</h2>
            <button class="btn btn-sm btn-primary" @onclick="() => showMedForm = true">+ Medikament</button>
        </div>

        @if (showMedForm)
        {
            <div class="inline-form">
                <div class="form-row">
                    <div class="form-group"><label>Medikament *</label><InputText @bind-Value="newMed.Name" class="form-control" placeholder="z.B. Sertralin" /></div>
                    <div class="form-group" style="flex:0.5"><label>Stärke</label><InputText @bind-Value="newMed.Staerke" class="form-control" placeholder="50mg" /></div>
                </div>
                <div class="form-row">
                    <div class="form-group"><label>Dosierung</label><InputText @bind-Value="newMed.Dosierung" class="form-control" placeholder="1-0-0-0" /></div>
                    <div class="form-group"><label>Wirkstoff</label><InputText @bind-Value="newMed.Wirkstoff" class="form-control" /></div>
                    <div class="form-group" style="flex:0.5"><label>Seit</label><InputDate @bind-Value="newMed.SeitDatum" class="form-control" /></div>
                </div>
                <div class="form-row">
                    <div class="form-group"><label>Hinweis</label><InputText @bind-Value="newMed.Hinweis" class="form-control" placeholder="z.B. zur Mahlzeit" /></div>
                </div>
                <div style="display:flex;gap:.5rem">
                    <button class="btn btn-primary btn-sm" @onclick="AddMedication">Hinzufügen</button>
                    <button class="btn btn-secondary btn-sm" @onclick="() => showMedForm = false">Abbrechen</button>
                </div>
            </div>
        }

        @if (medications is null || medications.Count == 0)
        {
            <div class="empty-encounters">Keine aktive Medikation.</div>
        }
        else
        {
            <div class="med-list">
                @foreach (var med in medications)
                {
                    <div class="med-item @(med.IsBtm ? "btm" : "")">
                        <div class="med-main">
                            <span class="med-name">@med.Name @med.Staerke</span>
                            @if (med.IsBtm) { <span class="btm-badge">BtM</span> }
                        </div>
                        <div class="med-details">
                            @if (!string.IsNullOrEmpty(med.Dosierung)) { <span>@med.Dosierung</span> }
                            @if (!string.IsNullOrEmpty(med.Hinweis)) { <span class="med-hint">@med.Hinweis</span> }
                            <span class="med-since">seit @med.SeitDatum.ToString("MM/yyyy")</span>
                        </div>
                        <button class="btn-link danger" @onclick="() => DeactivateMed(med.Id)">Absetzen</button>
                    </div>
                }
            </div>
        }
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Psychometrische Testung</h2>
            <div style="display:flex;gap:.5rem">
                <a href="/testung/ergebnisse/@Id" class="btn btn-sm btn-secondary">Alle Ergebnisse</a>
                <a href="/testung/auswahl/@Id" class="btn btn-sm btn-primary">+ Neuer Test</a>
            </div>
        </div>

        @if (recentTests is null || recentTests.Count == 0)
        {
            <div class="empty-encounters">Noch keine psychometrischen Tests durchgeführt.</div>
        }
        else
        {
            <div class="encounter-list">
                @foreach (var t in recentTests)
                {
                    <a href="/testung/durchfuehrung/@t.Id" class="encounter-item">
                        <div class="enc-date">
                            <span class="enc-day">@t.TestDate.ToString("dd")</span>
                            <span class="enc-month">@t.TestDate.ToString("MMM yy", new System.Globalization.CultureInfo("de-DE"))</span>
                        </div>
                        <div class="enc-details">
                            <span class="enc-doctor">@t.TestTypeName</span>
                            <span class="enc-codes">@t.TotalScore / @t.MaxScore — @t.Interpretation</span>
                        </div>
                        <div class="enc-meta">
                            <span class="enc-status status-@t.Status.ToString().ToLower()">
                                @(t.Status == MediPrax.Core.Enums.TestStatus.Completed ? "Abgeschlossen" : "In Bearbeitung")
                            </span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Krankheitsverlauf & Spezialmodule</h2>
        </div>
        <div class="detail-grid" style="margin-bottom:0.5rem;">
            @* Suizidalität *@
            <a href="/patienten/@Id/suizidalitaet" class="detail-card module-card">
                <h3>Suizidalität</h3>
                @if (lastSuicidality is not null)
                {
                    <div class="module-value @(lastSuicidality.RiskLevel >= MediPrax.Core.Enums.SuicidalityRiskLevel.Moderate ? "danger" : "")">@lastSuicidality.RiskLevelDisplay</div>
                    <div class="module-meta">@lastSuicidality.AssessmentDate.ToString("dd.MM.yyyy")</div>
                }
                else
                {
                    <div class="module-empty">Keine Einschätzung</div>
                }
            </a>

            @* Anfallskalender *@
            <a href="/patienten/@Id/anfallskalender" class="detail-card module-card">
                <h3>Anfallskalender</h3>
                @if (seizureEntries is not null && seizureEntries.Count > 0)
                {
                    <div class="module-value">@seizureEntries.Count(e => e.SeizureDate >= DateTime.UtcNow.AddDays(-30))</div>
                    <div class="module-meta">Anfälle / 30 Tage (gesamt: @seizureEntries.Count)</div>
                }
                else
                {
                    <div class="module-empty">Kein Eintrag</div>
                }
            </a>

            @* Kopfschmerz *@
            <a href="/patienten/@Id/kopfschmerz-tagebuch" class="detail-card module-card">
                <h3>Kopfschmerz-Tagebuch</h3>
                @if (headacheEntries is not null && headacheEntries.Count > 0)
                {
                    <div class="module-value">Ø @headacheEntries.Average(e => e.Intensity).ToString("F1") / 10</div>
                    <div class="module-meta">@headacheEntries.Count Einträge, letzter @headacheEntries.First().Date.ToString("dd.MM.yyyy")</div>
                }
                else
                {
                    <div class="module-empty">Kein Eintrag</div>
                }
            </a>

            @* MS *@
            <a href="/patienten/@Id/ms-dokumentation" class="detail-card module-card">
                <h3>Multiple Sklerose</h3>
                @if (msEntries is not null && msEntries.Count > 0)
                {
                    <div class="module-value">EDSS @msEntries.First().EdssScore.ToString("F1")</div>
                    <div class="module-meta">@msEntries.First().DocumentationDate.ToString("dd.MM.yyyy") · @msEntries.Count(e => e.IsRelapse) Schübe</div>
                }
                else
                {
                    <div class="module-empty">Kein Eintrag</div>
                }
            </a>

            @* Parkinson *@
            <a href="/patienten/@Id/parkinson-dokumentation" class="detail-card module-card">
                <h3>Parkinson</h3>
                @if (parkinsonEntries is not null && parkinsonEntries.Count > 0)
                {
                    <div class="module-value">H&Y @parkinsonEntries.First().HoehnYahrStage.ToString("F1")</div>
                    <div class="module-meta">Motor @parkinsonEntries.First().MotorScore/16 · @parkinsonEntries.First().DocumentationDate.ToString("dd.MM.yyyy")</div>
                }
                else
                {
                    <div class="module-empty">Kein Eintrag</div>
                }
            </a>

            @* Laborergebnisse *@
            <a href="/labor/@Id" class="detail-card module-card">
                <h3>Laborergebnisse</h3>
                @if (labResults is not null && labResults.Count > 0)
                {
                    var pending = labResults.Count(l => l.Status == MediPrax.Core.Enums.LabResultStatus.Ordered);
                    var unreviewed = labResults.Count(l => l.Status == MediPrax.Core.Enums.LabResultStatus.Received);
                    var critical = labResults.Count(l => l.HasCriticalValues);
                    <div class="module-value @(critical > 0 ? "danger" : "")">@labResults.Count</div>
                    <div class="module-meta">
                        @if (critical > 0) { <text>@critical kritisch · </text> }
                        @if (unreviewed > 0) { <text>@unreviewed ungelesen · </text> }
                        @if (pending > 0) { <text>@pending offen</text> }
                        @if (critical == 0 && unreviewed == 0 && pending == 0) { <text>Alle geprüft</text> }
                    </div>
                }
                else
                {
                    <div class="module-empty">Keine Laborergebnisse</div>
                }
            </a>
        </div>
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Wiedervorlagen</h2>
            <button class="btn btn-sm btn-primary" @onclick="() => showRecallForm = true">+ Wiedervorlage</button>
        </div>

        @if (showRecallForm)
        {
            <div class="inline-form">
                <div class="form-row">
                    <div class="form-group"><label>Fällig am *</label><InputDate @bind-Value="newRecall.DueDate" class="form-control" /></div>
                    <div class="form-group"><label>Grund *</label><InputText @bind-Value="newRecall.Reason" class="form-control" placeholder="z.B. Kontrolltermin" /></div>
                </div>
                <div style="display:flex;gap:.5rem">
                    <button class="btn btn-primary btn-sm" @onclick="AddRecall">Hinzufügen</button>
                    <button class="btn btn-secondary btn-sm" @onclick="() => showRecallForm = false">Abbrechen</button>
                </div>
            </div>
        }

        @if (recalls is null || recalls.Count == 0)
        {
            <div class="empty-encounters">Keine Wiedervorlagen.</div>
        }
        else
        {
            <div class="recall-list">
                @foreach (var r in recalls)
                {
                    <div class="recall-item @(r.IsOverdue ? "overdue" : "")">
                        <span class="recall-date">@r.DueDate.ToString("dd.MM.yyyy")</span>
                        <span class="recall-reason">@r.Reason</span>
                        <span class="recall-status">@r.StatusDisplay</span>
                        @if (r.Status == MediPrax.Core.Enums.RecallStatus.Open)
                        {
                            <button class="btn-link" @onclick="() => CompleteRecall(r.Id)">Erledigt</button>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (showDeleteConfirm)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>Patient <strong>@patient.FullName</strong> wirklich löschen?</p>
                <div class="confirm-actions">
                    <button @onclick="ConfirmDelete" class="btn btn-danger">Ja, löschen</button>
                    <button @onclick="() => showDeleteConfirm = false" class="btn btn-secondary">Abbrechen</button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PatientDto? patient;
    private IReadOnlyList<EncounterListItemDto>? encounters;
    private IReadOnlyList<ArztbriefListItemDto>? arztbriefe;
    private IReadOnlyList<MedicationDto>? medications;
    private IReadOnlyList<RecallDto>? recalls;
    private IReadOnlyList<PsychometricTestListItemDto>? recentTests;
    private IReadOnlyList<SeizureDiaryDto>? seizureEntries;
    private IReadOnlyList<HeadacheDiaryDto>? headacheEntries;
    private IReadOnlyList<MsDocumentationDto>? msEntries;
    private IReadOnlyList<ParkinsonDocumentationDto>? parkinsonEntries;
    private SuicidalityAssessmentDto? lastSuicidality;
    private IReadOnlyList<LabResultListItemDto>? labResults;
    private bool showDeleteConfirm, showMedForm, showRecallForm;
    private MedForm newMed = new();
    private RecallForm newRecall = new();

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(Id);
        if (patient is null)
        {
            Navigation.NavigateTo("/patienten");
            return;
        }
        encounters = await EncounterService.GetByPatientAsync(Id);
        arztbriefe = await ArztbriefService.GetByPatientAsync(Id);
        medications = await MedicationService.GetByPatientAsync(Id);
        recalls = await RecallService.GetByPatientAsync(Id);
        recentTests = await PsychometricTestService.GetByPatientAsync(Id);
        seizureEntries = await SeizureDiaryService.GetByPatientAsync(Id);
        headacheEntries = await HeadacheDiaryService.GetByPatientAsync(Id);
        msEntries = await MsDocService.GetByPatientAsync(Id);
        parkinsonEntries = await ParkinsonService.GetByPatientAsync(Id);
        lastSuicidality = await SuicidalityService.GetLatestByPatientAsync(Id);
        labResults = await LabResultService.GetByPatientAsync(Id);
        await AuditService.LogAsync(MediPrax.Core.Enums.AuditAction.Read, "Patient", Id, $"Patientenakte geöffnet: {patient.FullName}");
    }

    private async Task<Guid> GetCurrentUserId()
    {
        var auth = await AuthState!;
        return Guid.Parse(auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);
    }

    private async Task AddMedication()
    {
        var userId = await GetCurrentUserId();
        await MedicationService.AddAsync(new CreateMedicationDto
        {
            PatientId = Id, PrescribedById = userId,
            Name = newMed.Name, Wirkstoff = newMed.Wirkstoff,
            Staerke = newMed.Staerke, Dosierung = newMed.Dosierung,
            Hinweis = newMed.Hinweis, SeitDatum = newMed.SeitDatum
        });
        medications = await MedicationService.GetByPatientAsync(Id);
        newMed = new();
        showMedForm = false;
    }

    private async Task DeactivateMed(Guid id)
    {
        await MedicationService.DeactivateAsync(id);
        medications = await MedicationService.GetByPatientAsync(Id);
    }

    private async Task AddRecall()
    {
        var userId = await GetCurrentUserId();
        await RecallService.CreateAsync(new CreateRecallDto
        {
            PatientId = Id, CreatedById = userId,
            DueDate = newRecall.DueDate, Reason = newRecall.Reason
        });
        recalls = await RecallService.GetByPatientAsync(Id);
        newRecall = new();
        showRecallForm = false;
    }

    private async Task CompleteRecall(Guid id)
    {
        await RecallService.UpdateStatusAsync(id, MediPrax.Core.Enums.RecallStatus.Completed);
        recalls = await RecallService.GetByPatientAsync(Id);
    }

    private void HandleDelete() => showDeleteConfirm = true;

    private async Task ConfirmDelete()
    {
        await PatientService.DeleteAsync(Id);
        Navigation.NavigateTo("/patienten");
    }

    private class MedForm
    {
        public string Name { get; set; } = "";
        public string? Wirkstoff { get; set; }
        public string? Staerke { get; set; }
        public string? Dosierung { get; set; }
        public string? Hinweis { get; set; }
        public DateOnly SeitDatum { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    }

    private class RecallForm
    {
        public DateOnly DueDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddMonths(3));
        public string Reason { get; set; } = "";
    }
}
