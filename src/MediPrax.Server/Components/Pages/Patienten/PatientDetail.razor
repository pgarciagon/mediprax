@page "/patienten/{Id:guid}"
@attribute [Authorize]
@inject IPatientService PatientService
@inject IEncounterService EncounterService
@inject IArztbriefService ArztbriefService
@inject IAuditService AuditService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Patient — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <div class="page-header">
        <h1>@patient.FullName</h1>
        <div class="header-actions">
            <a href="/patienten/@Id/formulare" class="btn btn-secondary">Formulare</a>
            <a href="/patienten/@Id/bearbeiten" class="btn btn-primary">Bearbeiten</a>
            <button @onclick="HandleDelete" class="btn btn-danger">Löschen</button>
        </div>
    </div>

    <div class="detail-grid">
        <section class="detail-card">
            <h3>Persönliche Daten</h3>
            <dl>
                <dt>Name</dt>
                <dd>@patient.FirstName @patient.LastName</dd>

                <dt>Geburtsdatum</dt>
                <dd>@patient.DateOfBirth.ToString("dd.MM.yyyy")</dd>

                <dt>Geschlecht</dt>
                <dd>@(patient.Gender ?? "—")</dd>
            </dl>
        </section>

        <section class="detail-card">
            <h3>Versicherung</h3>
            <dl>
                <dt>Art</dt>
                <dd>@patient.InsuranceDisplay</dd>

                <dt>Krankenkasse</dt>
                <dd>@(patient.InsuranceProvider ?? "—")</dd>

                <dt>Versichertennr.</dt>
                <dd>@(patient.InsuranceNumber ?? "—")</dd>

                <dt>KVNR</dt>
                <dd>@(patient.Kvnr ?? "—")</dd>
            </dl>
        </section>

        <section class="detail-card">
            <h3>Kontakt & Adresse</h3>
            <dl>
                <dt>Telefon</dt>
                <dd>@(patient.Phone ?? "—")</dd>

                <dt>E-Mail</dt>
                <dd>@(patient.Email ?? "—")</dd>

                <dt>Adresse</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(patient.Street))
                    {
                        @patient.Street<br />
                    }
                    @if (!string.IsNullOrEmpty(patient.PostalCode) || !string.IsNullOrEmpty(patient.City))
                    {
                        @($"{patient.PostalCode} {patient.City}".Trim())
                    }
                    else
                    {
                        <text>—</text>
                    }
                </dd>
            </dl>
        </section>
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Klinische Dokumentation</h2>
            <a href="/patienten/@Id/dokumentation/neu" class="btn btn-sm btn-primary">+ Neue Dokumentation</a>
        </div>

        @if (encounters is null)
        {
            <p>Laden...</p>
        }
        else if (encounters.Count == 0)
        {
            <div class="empty-encounters">Noch keine Dokumentation vorhanden.</div>
        }
        else
        {
            <div class="encounter-list">
                @foreach (var enc in encounters)
                {
                    <a href="/dokumentation/@enc.Id/bearbeiten" class="encounter-item">
                        <div class="enc-date">
                            <span class="enc-day">@enc.EncounterDate.ToString("dd")</span>
                            <span class="enc-month">@enc.EncounterDate.ToString("MMM yy", new System.Globalization.CultureInfo("de-DE"))</span>
                        </div>
                        <div class="enc-details">
                            <span class="enc-doctor">@enc.DoctorName</span>
                            <span class="enc-codes">
                                @if (enc.Icd10Codes.Count > 0)
                                {
                                    @string.Join(", ", enc.Icd10Codes)
                                }
                                else
                                {
                                    <text>Keine Diagnosen</text>
                                }
                            </span>
                        </div>
                        <div class="enc-meta">
                            @if (enc.DurationMinutes.HasValue)
                            {
                                <span>@enc.DurationMinutes Min.</span>
                            }
                            <span class="enc-status status-@enc.Status.ToString().ToLower()">@enc.Status</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div class="encounters-section">
        <div class="section-header">
            <h2>Arztbriefe</h2>
            <a href="/patienten/@Id/arztbrief/neu" class="btn btn-sm btn-primary">+ Neuer Arztbrief</a>
        </div>

        @if (arztbriefe is null || arztbriefe.Count == 0)
        {
            <div class="empty-encounters">Noch keine Arztbriefe vorhanden.</div>
        }
        else
        {
            <div class="encounter-list">
                @foreach (var brief in arztbriefe)
                {
                    <a href="/dokumente/@brief.Id/pdf" target="_blank" class="encounter-item">
                        <div class="enc-date">
                            <svg style="width:20px;height:20px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div class="enc-details">
                            <span class="enc-doctor">@brief.Title</span>
                            <span class="enc-codes">@brief.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <div class="enc-meta">
                            <span class="enc-status status-completed">PDF</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    @if (showDeleteConfirm)
    {
        <div class="confirm-overlay">
            <div class="confirm-dialog">
                <p>Patient <strong>@patient.FullName</strong> wirklich löschen?</p>
                <div class="confirm-actions">
                    <button @onclick="ConfirmDelete" class="btn btn-danger">Ja, löschen</button>
                    <button @onclick="() => showDeleteConfirm = false" class="btn btn-secondary">Abbrechen</button>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PatientDto? patient;
    private IReadOnlyList<EncounterListItemDto>? encounters;
    private IReadOnlyList<ArztbriefListItemDto>? arztbriefe;
    private bool showDeleteConfirm;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(Id);
        if (patient is null)
        {
            Navigation.NavigateTo("/patienten");
            return;
        }
        encounters = await EncounterService.GetByPatientAsync(Id);
        arztbriefe = await ArztbriefService.GetByPatientAsync(Id);
        await AuditService.LogAsync(MediPrax.Core.Enums.AuditAction.Read, "Patient", Id, $"Patientenakte geöffnet: {patient.FullName}");
    }

    private void HandleDelete() => showDeleteConfirm = true;

    private async Task ConfirmDelete()
    {
        await PatientService.DeleteAsync(Id);
        Navigation.NavigateTo("/patienten");
    }
}
