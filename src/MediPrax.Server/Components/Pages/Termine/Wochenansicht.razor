@page "/termine"
@attribute [Authorize]
@inject IAppointmentService AppointmentService
@inject IUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Terminplanung</PageTitle>
<style>.main-content:has(.week-grid), .main-content:has(.timeline-grid) { max-width: none !important; }</style>

<div class="page-header">
    <h1>Terminplanung</h1>
    <div class="header-actions">
        <a href="/termine/neu" class="btn btn-primary">+ Neuer Termin</a>
        <a href="/terminserie/neu" class="btn btn-secondary">Serie erstellen</a>
        <a href="/warteliste" class="btn btn-secondary">Warteliste</a>
    </div>
</div>

<div class="toolbar">
    <div class="week-nav">
        <button class="btn btn-secondary btn-sm" @onclick="NavigateBack">&larr;</button>
        <button class="btn btn-secondary btn-sm" @onclick="GoToToday">Heute</button>
        <button class="btn btn-secondary btn-sm" @onclick="NavigateForward">&rarr;</button>
        <span class="week-label">
            @if (viewMode == "tag")
            {
                @($"{GetDayName(selectedDate.DayOfWeek)}, {selectedDate:dd.MM.yyyy}")
            }
            else
            {
                @($"{weekStart:dd.MM.} – {weekStart.AddDays(6):dd.MM.yyyy}")
            }
        </span>
    </div>

    <div style="display:flex;gap:0.5rem;align-items:center;">
        <div class="view-toggle">
            <button class="btn btn-sm @(viewMode == "tag" ? "btn-primary" : "btn-secondary")" @onclick='() => viewMode = "tag"'>Tag</button>
            <button class="btn btn-sm @(viewMode == "kalender" ? "btn-primary" : "btn-secondary")" @onclick='() => viewMode = "kalender"'>Woche</button>
            <button class="btn btn-sm @(viewMode == "liste" ? "btn-primary" : "btn-secondary")" @onclick='() => viewMode = "liste"'>Liste</button>
        </div>
        <label style="font-size:0.78rem;display:flex;align-items:center;gap:0.3rem;color:var(--color-text-secondary);cursor:pointer;">
            <input type="checkbox" @bind="showWeekend" style="width:auto;margin:0;" /> Sa/So
        </label>
        <div class="doctor-filter">
            <select class="form-control" @bind="selectedDoctorId" @bind:after="LoadSchedule">
                <option value="">Alle Ärzte</option>
                @foreach (var doc in doctors)
                {
                    <option value="@doc.Id">@doc.FullName</option>
                }
            </select>
        </div>
    </div>
</div>

@if (schedule is null)
{
    <p>Laden...</p>
}
else if (viewMode == "tag")
{
    @* === DAY VIEW === *@
    var dayData = schedule.Days.FirstOrDefault(d => d.Date == selectedDate);
    var dayAppts = dayData?.Appointments.ToList() ?? [];
    <div class="timeline-container" style="display:flex;">
        @* Time axis *@
        <div class="time-axis" style="flex:0 0 55px;">
            <div class="time-axis-header" style="height:48px;"></div>
            @for (var h = startHour; h < endHour; h++)
            {
                <div class="time-label" style="height:@(slotHeight * 2)px;">
                    <span>@($"{h:00}:00")</span>
                </div>
            }
        </div>
        @* Single day, full width *@
        <div class="timeline-day today" style="flex:1;">
            <div class="timeline-day-header">
                <span class="day-name" style="font-size:0.9rem;">@GetDayName(selectedDate.DayOfWeek), @selectedDate.ToString("dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE"))</span>
            </div>
            <div class="timeline-slots" style="height:@((endHour - startHour) * slotHeight * 2)px;position:relative;">
                @for (var h = startHour; h < endHour; h++)
                {
                    var topHour = (h - startHour) * slotHeight * 2;
                    <div class="grid-line" style="top:@(topHour)px;"></div>
                    <div class="grid-line half" style="top:@(topHour + slotHeight)px;"></div>
                }

                @{ var dayLayout = CalculateLayout(dayAppts); }
                @foreach (var item in dayLayout)
                {
                    var appt = item.Appt;
                    var color = GetDoctorColor(appt.DoctorName);
                    var widthPct = 100.0 / item.TotalColumns;
                    var leftPct = widthPct * item.Column;

                    <div class="timeline-appt status-@appt.Status.ToString().ToLower()"
                         style="top:@(item.Top)px;height:@(item.Height)px;left:@(F(leftPct))%;width:calc(@(F(widthPct))% - 4px);border-left-color:@color;background:@(color)12;"
                         @onclick="() => ViewAppointment(appt.Id)"
                         title="@appt.PatientName — @appt.Notes">
                        <span class="appt-time">@item.StartLocal.ToString("HH:mm") – @appt.EndTime.ToLocalTime().ToString("HH:mm")</span>
                        <span class="appt-patient">@appt.PatientName</span>
                        @if (!string.IsNullOrEmpty(appt.DoctorName))
                        {
                            <span class="appt-doctor" style="color:@color;font-weight:600;">@appt.DoctorName</span>
                        }
                        @if (!string.IsNullOrEmpty(appt.Notes) && item.Height > 45)
                        {
                            <span class="appt-notes">@appt.Notes</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (viewMode == "liste")
{
    @* === LISTE VIEW (existing) === *@
    <div class="week-grid">
        @foreach (var day in schedule.Days.Take(showWeekend ? 7 : 5))
        {
            var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
            <div class="day-column @(isToday ? "today" : "")">
                <div class="day-header">
                    <span class="day-name">@GetDayName(day.Date.DayOfWeek)</span>
                    <span class="day-date @(isToday ? "today-badge" : "")">@day.Date.ToString("dd.MM.")</span>
                </div>
                <div class="day-slots">
                    @if (day.Appointments.Count == 0)
                    {
                        <div class="empty-day">—</div>
                    }
                    else
                    {
                        @foreach (var appt in day.Appointments)
                        {
                            <div class="appointment-slot status-@appt.Status.ToString().ToLower()" @onclick="() => ViewAppointment(appt.Id)">
                                <span class="slot-time">@appt.StartTime.ToLocalTime().ToString("HH:mm")</span>
                                <span class="slot-patient">@appt.PatientName</span>
                                @if (!string.IsNullOrEmpty(appt.DoctorName) && string.IsNullOrEmpty(selectedDoctorId))
                                {
                                    <span class="slot-doctor">@appt.DoctorName</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    @* === KALENDER/TIMELINE VIEW === *@
    <div class="timeline-container">
        <div class="timeline-grid">
            @* Time axis column *@
            <div class="time-axis">
                <div class="time-axis-header"></div>
                @for (var h = startHour; h < endHour; h++)
                {
                    <div class="time-label" style="height:@(slotHeight * 2)px;">
                        <span>@($"{h:00}:00")</span>
                    </div>
                }
            </div>

            @* Day columns *@
            @foreach (var day in schedule.Days.Take(showWeekend ? 7 : 5))
            {
                var isToday = day.Date == DateOnly.FromDateTime(DateTime.Today);
                var dayAppts = day.Appointments.ToList();

                <div class="timeline-day @(isToday ? "today" : "")">
                    <div class="timeline-day-header">
                        <span class="day-name">@GetDayName(day.Date.DayOfWeek)</span>
                        <span class="day-date @(isToday ? "today-badge" : "")">@day.Date.ToString("dd.MM.")</span>
                    </div>
                    <div class="timeline-slots" style="height:@((endHour - startHour) * slotHeight * 2)px;position:relative;">
                        @* Half-hour grid lines *@
                        @for (var h = startHour; h < endHour; h++)
                        {
                            var topHour = (h - startHour) * slotHeight * 2;
                            <div class="grid-line" style="top:@(topHour)px;"></div>
                            <div class="grid-line half" style="top:@(topHour + slotHeight)px;"></div>
                        }

                        @* Appointment blocks (with overlap handling) *@
                        @{ var layout = CalculateLayout(dayAppts); }
                        @foreach (var item in layout)
                        {
                            var appt = item.Appt;
                            var color = GetDoctorColor(appt.DoctorName);
                            var widthPct = 100.0 / item.TotalColumns;
                            var leftPct = widthPct * item.Column;
                            var cols = item.TotalColumns;

                            <div class="timeline-appt status-@appt.Status.ToString().ToLower()"
                                 style="top:@(item.Top)px;height:@(item.Height)px;left:@(F(leftPct))%;width:calc(@(F(widthPct))% - 3px);border-left-color:@color;background:@(color)12;"
                                 @onclick="() => ViewAppointment(appt.Id)"
                                 title="@appt.PatientName — @item.StartLocal.ToString("HH:mm")–@appt.EndTime.ToLocalTime().ToString("HH:mm") — @appt.Notes">
                                @{ var allDocs = string.IsNullOrEmpty(selectedDoctorId); }
                                @if (cols <= 3)
                                {
                                    @* Full detail *@
                                    <span class="appt-time">@item.StartLocal.ToString("HH:mm")–@appt.EndTime.ToLocalTime().ToString("HH:mm")</span>
                                    <span class="appt-patient">@appt.PatientName</span>
                                    @if (!string.IsNullOrEmpty(appt.DoctorName) && allDocs && item.Height > 35)
                                    {
                                        <span class="appt-doctor">@appt.DoctorName</span>
                                    }
                                    @if (!string.IsNullOrEmpty(appt.Notes) && item.Height > 55)
                                    {
                                        <span class="appt-notes">@appt.Notes</span>
                                    }
                                }
                                else if (cols <= 5)
                                {
                                    @* Compact: time + short name, doctor initials if all docs *@
                                    <span class="appt-time">@item.StartLocal.ToString("HH:mm")</span>
                                    <span class="appt-patient">@GetShortName(appt.PatientName)</span>
                                    @if (allDocs && !string.IsNullOrEmpty(appt.DoctorName))
                                    {
                                        <span class="appt-doctor">@GetInitials(appt.DoctorName)</span>
                                    }
                                }
                                else
                                {
                                    @* Minimal: doctor initials (in Alle Ärzte) or patient initials *@
                                    <span class="appt-patient" style="font-size:0.65rem;">@(allDocs ? GetInitials(appt.DoctorName) : GetInitials(appt.PatientName))</span>
                                }
                            </div>
                        }

                        @* Click empty area to create *@
                        <div class="timeline-click-area" @onclick="(e) => CreateAtSlot(day.Date, e)"></div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private WeekScheduleDto? schedule;
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private DateOnly weekStart;
    private string selectedDoctorId = string.Empty;
    private string viewMode = "kalender";
    private bool showWeekend;
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Today);

    private const int startHour = 8;
    private const int endHour = 18;
    private const int slotHeight = 36; // pixels per 30 min

    protected override async Task OnInitializedAsync()
    {
        weekStart = GetMonday(DateOnly.FromDateTime(DateTime.Today));
        doctors = await UserService.GetDoctorsAsync();
        await LoadSchedule();
    }

    private async Task LoadSchedule()
    {
        Guid? doctorId = Guid.TryParse(selectedDoctorId, out var id) ? id : null;
        schedule = await AppointmentService.GetWeekScheduleAsync(weekStart, doctorId);
    }

    private async Task NavigateBack()
    {
        if (viewMode == "tag") { selectedDate = selectedDate.AddDays(-1); weekStart = GetMonday(selectedDate); }
        else { weekStart = weekStart.AddDays(-7); selectedDate = weekStart; }
        await LoadSchedule();
    }

    private async Task NavigateForward()
    {
        if (viewMode == "tag") { selectedDate = selectedDate.AddDays(1); weekStart = GetMonday(selectedDate); }
        else { weekStart = weekStart.AddDays(7); selectedDate = weekStart; }
        await LoadSchedule();
    }

    private async Task GoToToday()
    {
        selectedDate = DateOnly.FromDateTime(DateTime.Today);
        weekStart = GetMonday(selectedDate);
        await LoadSchedule();
    }

    private void ViewAppointment(Guid id) => Navigation.NavigateTo($"/termine/{id}");

    private void CreateAtSlot(DateOnly date, Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        Navigation.NavigateTo($"/termine/neu");
    }

    private static DateOnly GetMonday(DateOnly date)
    {
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff);
    }

    private static string GetDayName(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Mo",
        DayOfWeek.Tuesday => "Di",
        DayOfWeek.Wednesday => "Mi",
        DayOfWeek.Thursday => "Do",
        DayOfWeek.Friday => "Fr",
        DayOfWeek.Saturday => "Sa",
        _ => "So"
    };

    // --- Overlap layout algorithm ---
    private record LayoutItem(AppointmentDto Appt, int Top, int Height, DateTime StartLocal, int Column, int TotalColumns);

    private List<LayoutItem> CalculateLayout(List<AppointmentDto> appts)
    {
        if (appts.Count == 0) return [];

        // Build positioned items with time info
        var items = appts
            .Select(a =>
            {
                var localTime = a.StartTime.ToLocalTime();
                var minutesFromStart = (localTime.Hour - startHour) * 60 + localTime.Minute;
                var top = (int)(minutesFromStart * slotHeight / 30.0);
                var height = Math.Max((int)(a.DurationMinutes * slotHeight / 30.0), slotHeight / 2);
                var endMinutes = minutesFromStart + a.DurationMinutes;
                return new { Appt = a, Top = top, Height = height, StartLocal = localTime, StartMin = minutesFromStart, EndMin = endMinutes };
            })
            .Where(x => x.StartMin >= 0)
            .OrderBy(x => x.StartMin)
            .ThenBy(x => x.EndMin)
            .ToList();

        // Assign columns using greedy algorithm
        var columns = new List<int>(); // tracks end-minute of last appt in each column
        var assigned = new List<(int col, int totalCols)>();

        // Group into overlap clusters
        var clusters = new List<List<int>>(); // indices into items
        var clusterEnd = 0;
        var currentCluster = new List<int>();

        for (var i = 0; i < items.Count; i++)
        {
            if (currentCluster.Count > 0 && items[i].StartMin >= clusterEnd)
            {
                clusters.Add(currentCluster);
                currentCluster = [];
            }
            currentCluster.Add(i);
            clusterEnd = Math.Max(clusterEnd, items[i].EndMin);
        }
        if (currentCluster.Count > 0) clusters.Add(currentCluster);

        // For each cluster, assign columns
        var itemColumns = new int[items.Count];
        var itemTotalCols = new int[items.Count];

        foreach (var cluster in clusters)
        {
            var cols = new List<int>(); // end-minute per column
            foreach (var idx in cluster)
            {
                var placed = false;
                for (var c = 0; c < cols.Count; c++)
                {
                    if (items[idx].StartMin >= cols[c])
                    {
                        itemColumns[idx] = c;
                        cols[c] = items[idx].EndMin;
                        placed = true;
                        break;
                    }
                }
                if (!placed)
                {
                    itemColumns[idx] = cols.Count;
                    cols.Add(items[idx].EndMin);
                }
            }
            var totalCols = cols.Count;
            foreach (var idx in cluster)
                itemTotalCols[idx] = totalCols;
        }

        return items.Select((x, i) => new LayoutItem(x.Appt, x.Top, x.Height, x.StartLocal, itemColumns[i], itemTotalCols[i])).ToList();
    }

    private static string F(double v) => v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private static string GetShortName(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        // "Weber, Klaus" → "Weber, K." / "Klaus Weber" → "K. Weber"
        var parts = name.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0]}, {parts[1][0]}.";
        return name.Length > 8 ? name[..8] + "." : name;
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        // "Dr. Thomas Meier" → "TM", "Weber, Klaus" → "KW", "Anna Schmidt" → "AS"
        var clean = name.Replace("Dr.", "").Replace("dr.", "").Trim();
        var parts = clean.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            // If "LastName, FirstName" format
            if (name.Contains(','))
                return $"{parts[1][0]}{parts[0][0]}".ToUpper();
            // If "FirstName LastName" format — take first of first, first of last
            return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
        }
        return parts[0][..1].ToUpper();
    }

    private static string GetDoctorColor(string? doctorName)
    {
        if (string.IsNullOrEmpty(doctorName)) return "#2563eb";
        var hash = doctorName.GetHashCode();
        var colors = new[] { "#2563eb", "#7c3aed", "#059669", "#d97706", "#dc2626", "#0891b2" };
        return colors[Math.Abs(hash) % colors.Length];
    }
}
