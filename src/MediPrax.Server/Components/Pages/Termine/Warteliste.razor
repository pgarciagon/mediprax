@page "/warteliste"
@attribute [Authorize(Policy = "Klinisch")]
@inject IAppointmentService AppointmentService
@inject IUserService UserService
@inject IPatientService PatientService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Warteliste — Therapieplätze</PageTitle>

<div class="page-header">
    <div>
        <h1>Warteliste</h1>
        <span style="font-size:0.8rem;color:var(--color-text-secondary);">Patienten die auf einen Therapieplatz warten</span>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="() => showAddForm = !showAddForm">+ Neuer Eintrag</button>
</div>

@if (stats is not null)
{
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-value">@stats.TotalWaiting</div>
            <div class="kpi-label">Wartend</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-value">@stats.AverageWaitDays.ToString("F0")</div>
            <div class="kpi-label">Ø Wartetage</div>
        </div>
        <div class="kpi-card urgent">
            <div class="kpi-value">@stats.UrgentCount</div>
            <div class="kpi-label">Dringend</div>
        </div>
        @foreach (var q in stats.TherapistQueues)
        {
            <div class="kpi-card">
                <div class="kpi-value">@q.QueueLength</div>
                <div class="kpi-label">@q.TherapistName</div>
            </div>
        }
    </div>
}

@if (showAddForm)
{
    <div class="card form-card">
        <h3>Patient zur Warteliste hinzufügen</h3>
        <div class="form-row">
            <div class="form-group" style="position:relative;">
                <label>Patient suchen</label>
                <input class="form-control" @bind="patientSearch" @bind:event="oninput" @bind:after="SearchPatients" placeholder="Name eingeben..." />
                @if (searchResults.Count > 0)
                {
                    <div class="search-dropdown">
                        @foreach (var p in searchResults)
                        {
                            <div class="search-item" @onclick="() => SelectPatient(p)">
                                <span class="item-name">@p.FullName</span>
                                <span class="item-detail">@p.DateOfBirth.ToString("dd.MM.yyyy")</span>
                            </div>
                        }
                    </div>
                }
                @if (selectedPatient is not null)
                {
                    <small style="color:var(--color-primary);">Gewählt: @selectedPatient.FullName</small>
                }
            </div>
            <div class="form-group">
                <label>Bevorzugter Therapeut</label>
                <select class="form-control" @bind="newEntry.PreferredTherapistId">
                    <option value="">— Kein Präferenz —</option>
                    @foreach (var doc in doctors)
                    {
                        <option value="@doc.Id">@doc.FullName</option>
                    }
                </select>
            </div>
            <div class="form-group" style="flex:0.5;">
                <label>Priorität</label>
                <select class="form-control" @bind="newEntry.Priority">
                    <option value="@WaitlistPriority.Normal">Normal</option>
                    <option value="@WaitlistPriority.Urgent">Dringend</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group" style="flex:0.5;">
                <label>Bevorzugte Zeit</label>
                <select class="form-control" @bind="newEntry.PreferredTimeSlot">
                    <option value="">— Egal —</option>
                    <option value="Vormittags">Vormittags</option>
                    <option value="Nachmittags">Nachmittags</option>
                </select>
            </div>
            <div class="form-group">
                <label>Anmerkungen</label>
                <input class="form-control" @bind="newEntry.Notes" placeholder="z.B. Therapieform, besondere Umstände..." />
            </div>
        </div>
        <div style="display:flex;gap:0.5rem;margin-top:0.5rem;">
            <button class="btn btn-primary btn-sm" @onclick="AddToWaitlist" disabled="@(selectedPatient is null)">Hinzufügen</button>
            <button class="btn btn-secondary btn-sm" @onclick="() => showAddForm = false">Abbrechen</button>
        </div>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="color:var(--color-danger);font-size:0.8rem;margin-top:0.5rem;">@errorMessage</div>
        }
    </div>
}

<div class="filter-bar">
    <select class="form-control" style="max-width:180px;" @bind="filterStatus" @bind:after="LoadWaitlist">
        <option value="">Alle Status</option>
        <option value="@WaitlistStatus.Waiting">Wartend</option>
        <option value="@WaitlistStatus.Offered">Angeboten</option>
        <option value="@WaitlistStatus.Scheduled">Eingeplant</option>
        <option value="@WaitlistStatus.Cancelled">Storniert</option>
    </select>
    <select class="form-control" style="max-width:220px;" @bind="filterTherapistId" @bind:after="LoadWaitlist">
        <option value="">Alle Therapeuten</option>
        @foreach (var doc in doctors)
        {
            <option value="@doc.Id">@doc.FullName</option>
        }
    </select>
</div>

@if (entries is null)
{
    <p>Laden...</p>
}
else if (entries.Count == 0)
{
    <div class="empty-state">Keine Einträge in der Warteliste.</div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Wartetage</th>
                <th>Priorität</th>
                <th>Therapeut</th>
                <th>Zeit</th>
                <th>Status</th>
                <th>Anmerkungen</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in entries)
            {
                <tr class="@(entry.Priority == WaitlistPriority.Urgent ? "row-urgent" : "")">
                    <td style="font-weight:500;">@entry.PatientName</td>
                    <td>
                        <span class="wait-days @(entry.WaitDays > 90 ? "critical" : entry.WaitDays > 30 ? "warning" : "")">
                            @entry.WaitDays Tage
                        </span>
                    </td>
                    <td><span class="badge badge-@(entry.Priority == WaitlistPriority.Urgent ? "danger" : "secondary")">@entry.PriorityDisplay</span></td>
                    <td>@(entry.PreferredTherapistName ?? "—")</td>
                    <td>@(entry.PreferredTimeSlot ?? "—")</td>
                    <td><span class="badge badge-@GetStatusColor(entry.Status)">@entry.StatusDisplay</span></td>
                    <td style="font-size:0.78rem;color:var(--color-text-secondary);">@(entry.Notes ?? "—")</td>
                    <td style="white-space:nowrap;">
                        @if (entry.Status == WaitlistStatus.Waiting)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => OfferSlot(entry.Id)">Anbieten</button>
                            <button class="btn btn-sm btn-link danger" @onclick="() => CancelEntry(entry.Id)">Stornieren</button>
                        }
                        @if (entry.Status == WaitlistStatus.Offered)
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => ScheduleEntry(entry)">Einplanen</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => ResetToWaiting(entry.Id)">Zurück</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<WaitlistEntryDto>? entries;
    private WaitlistStatisticsDto? stats;
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private WaitlistStatus? filterStatus;
    private string filterTherapistId = string.Empty;

    private bool showAddForm;
    private CreateWaitlistEntryDto newEntry = new();
    private string patientSearch = string.Empty;
    private IReadOnlyList<PatientListItemDto> searchResults = [];
    private PatientListItemDto? selectedPatient;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        doctors = await UserService.GetDoctorsAsync();
        await LoadWaitlist();
    }

    private async Task LoadWaitlist()
    {
        Guid? therapistId = Guid.TryParse(filterTherapistId, out var id) ? id : null;
        entries = await AppointmentService.GetWaitlistAsync(filterStatus, therapistId);
        stats = await AppointmentService.GetWaitlistStatisticsAsync();
    }

    private async Task SearchPatients()
    {
        if (patientSearch.Length < 2) { searchResults = []; return; }
        var result = await PatientService.SearchAsync(new PatientSearchDto { SearchTerm = patientSearch, Page = 1, PageSize = 8 });
        searchResults = result.Items.Take(8).ToList();
    }

    private void SelectPatient(PatientListItemDto patient)
    {
        selectedPatient = patient;
        newEntry.PatientId = patient.Id;
        patientSearch = patient.FullName;
        searchResults = [];
    }

    private async Task AddToWaitlist()
    {
        if (selectedPatient is null) return;
        errorMessage = null;
        try
        {
            await AppointmentService.AddToWaitlistAsync(newEntry);
            showAddForm = false;
            newEntry = new();
            selectedPatient = null;
            patientSearch = string.Empty;
            await LoadWaitlist();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task OfferSlot(Guid entryId)
    {
        await AppointmentService.UpdateWaitlistStatusAsync(entryId, WaitlistStatus.Offered);
        await LoadWaitlist();
    }

    private void ScheduleEntry(WaitlistEntryDto entry)
    {
        var url = $"/termine/neu?patientIdQuery={entry.PatientId}";
        if (entry.PreferredTherapistId.HasValue)
            url += $"&doctorIdQuery={entry.PreferredTherapistId.Value}";
        if (!string.IsNullOrEmpty(entry.Notes))
            url += $"&notesQuery={Uri.EscapeDataString(entry.Notes)}";
        Navigation.NavigateTo(url);
    }

    private async Task CancelEntry(Guid entryId)
    {
        await AppointmentService.UpdateWaitlistStatusAsync(entryId, WaitlistStatus.Cancelled);
        await LoadWaitlist();
    }

    private async Task ResetToWaiting(Guid entryId)
    {
        await AppointmentService.UpdateWaitlistStatusAsync(entryId, WaitlistStatus.Waiting);
        await LoadWaitlist();
    }

    private static string GetStatusColor(WaitlistStatus status) => status switch
    {
        WaitlistStatus.Waiting => "warning",
        WaitlistStatus.Offered => "info",
        WaitlistStatus.Scheduled => "success",
        WaitlistStatus.Cancelled => "secondary",
        _ => "secondary"
    };
}
