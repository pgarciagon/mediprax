@page "/termine/neu"
@page "/termine/{Id:guid}"
@attribute [Authorize]
@inject IAppointmentService AppointmentService
@inject IPatientService PatientService
@inject IUserService UserService
@inject ISlotSuggestionService SlotSuggestionService
@inject IAvailabilityService AvailabilityService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Termin bearbeiten" : "Neuer Termin")</PageTitle>

<div class="page-header">
    <h1>@(IsEdit ? "Termin bearbeiten" : "Neuer Termin")</h1>
</div>

@if (notFound)
{
    <p>Termin nicht gefunden.</p>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">@errorMessage</div>
    }

    <div class="form-container">
        <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="appointmentForm">
            <fieldset>
                <legend>Termin</legend>

                <div class="form-row">
                    <div class="form-group">
                        <label>Patient *</label>
                        <div class="patient-search">
                            <input type="text"
                                   @bind="patientSearchTerm"
                                   @bind:event="oninput"
                                   @bind:after="SearchPatients"
                                   placeholder="Patient suchen..."
                                   class="form-control" />
                            @if (patientResults is not null && patientResults.Items.Count > 0 && !patientSelected)
                            {
                                <div class="search-dropdown">
                                    @foreach (var p in patientResults.Items)
                                    {
                                        <div class="search-item" @onclick="() => SelectPatient(p)">
                                            <span class="item-name">@p.FullName</span>
                                            <span class="item-detail">@p.DateOfBirth.ToString("dd.MM.yyyy")</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Arzt *</label>
                        <InputSelect @bind-Value="form.DoctorId" class="form-control">
                            <option value="">— Arzt wählen —</option>
                            @foreach (var doc in doctors)
                            {
                                <option value="@doc.Id">@doc.FullName</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Terminart</label>
                        <select class="form-control" @bind="selectedTemplate" @bind:after="ApplyTemplate">
                            <option value="">— Freitext —</option>
                            @foreach (var t in appointmentTemplates)
                            {
                                <option value="@t.Name">@t.Name (@t.DefaultDurationMinutes Min.)</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Datum *</label>
                        <InputDate @bind-Value="form.Date" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Uhrzeit *</label>
                        <InputText @bind-Value="form.Time" class="form-control" placeholder="08:00" />
                    </div>
                    <div class="form-group" style="flex: 0.5">
                        <label>Dauer (Min.)</label>
                        <InputNumber @bind-Value="form.DurationMinutes" class="form-control" />
                    </div>
                </div>

                @* Slot-Suggestion *@
                @if (!IsEdit)
                {
                    <div class="slot-suggestion-section">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Bevorzugter Tag</label>
                                <select class="form-control" @bind="preferredDay">
                                    <option value="">— Egal —</option>
                                    <option value="1">Montag</option>
                                    <option value="2">Dienstag</option>
                                    <option value="3">Mittwoch</option>
                                    <option value="4">Donnerstag</option>
                                    <option value="5">Freitag</option>
                                    <option value="6">Samstag</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Bevorzugte Uhrzeit</label>
                                <InputText @bind-Value="preferredTimeStr" class="form-control" placeholder="z.B. 10:00" />
                            </div>
                            <div class="form-group" style="flex:0.6;align-self:end">
                                <button type="button" class="btn btn-outline" @onclick="SearchSlots" disabled="@searchingSlots">
                                    @(searchingSlots ? "Suche..." : "Freien Slot suchen")
                                </button>
                            </div>
                        </div>

                        @if (slotError is not null)
                        {
                            <div class="slot-info">@slotError</div>
                        }

                        @if (suggestedSlots is not null && suggestedSlots.Count > 0)
                        {
                            <div class="slot-results">
                                @foreach (var slot in suggestedSlots)
                                {
                                    <button type="button" class="slot-chip" @onclick="() => ApplySlot(slot)">
                                        <span class="slot-date">@slot.Start.ToLocalTime().ToString("ddd dd.MM.")</span>
                                        <span class="slot-time">@slot.Start.ToLocalTime().ToString("HH:mm")–@slot.End.ToLocalTime().ToString("HH:mm")</span>
                                        <span class="slot-doctor">@slot.DoctorName</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="form-row">
                    <div class="form-group full">
                        <label>Notizen</label>
                        <InputTextArea @bind-Value="form.Notes" class="form-control" rows="2" />
                    </div>
                </div>
            </fieldset>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "Speichern..." : IsEdit ? "Speichern" : "Termin anlegen")
                </button>
                @if (IsEdit && form.PatientId != Guid.Empty)
                {
                    <a href="/patienten/@form.PatientId/dokumentation/neu?DoctorIdQuery=@form.DoctorId&DurationQuery=@form.DurationMinutes&AppointmentIdQuery=@Id" class="btn btn-accent">
                        Konsultation starten
                    </a>
                }
                <a href="@backUrl" class="btn btn-secondary">Abbrechen</a>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery] public Guid? PatientIdQuery { get; set; }
    [SupplyParameterFromQuery] public Guid? DoctorIdQuery { get; set; }
    [SupplyParameterFromQuery] public string? NotesQuery { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private string backUrl => !string.IsNullOrEmpty(ReturnUrl) ? Uri.UnescapeDataString(ReturnUrl) : "/termine";

    private bool IsEdit => Id.HasValue;
    private bool notFound;
    private AppointmentFormModel form = new();
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private IReadOnlyList<AppointmentTypeTemplate> appointmentTemplates = AppointmentTypeCatalog.AllTemplates;
    private string selectedTemplate = string.Empty;
    private PagedResult<PatientListItemDto>? patientResults;
    private string patientSearchTerm = string.Empty;
    private bool patientSelected;
    private bool saving;
    private string? errorMessage;
    private static readonly TimeZoneInfo berlinTz = TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin");

    protected override async Task OnInitializedAsync()
    {
        doctors = await UserService.GetDoctorsAsync();

        if (IsEdit)
        {
            var appointment = await AppointmentService.GetByIdAsync(Id!.Value);
            if (appointment is null)
            {
                notFound = true;
                return;
            }

            form.PatientId = appointment.PatientId;
            form.DoctorId = appointment.DoctorId.ToString();
            var localStart = TimeZoneInfo.ConvertTimeFromUtc(
                DateTime.SpecifyKind(appointment.StartTime, DateTimeKind.Utc), berlinTz);
            form.Date = DateOnly.FromDateTime(localStart);
            form.Time = localStart.ToString("HH:mm");
            form.DurationMinutes = appointment.DurationMinutes;
            form.Notes = appointment.Notes;
            selectedTemplate = appointment.AppointmentType ?? "";
            patientSearchTerm = appointment.PatientName;
            patientSelected = true;
        }
        else
        {
            // Pre-fill from query parameters (e.g. from Warteliste)
            if (PatientIdQuery.HasValue)
            {
                var patient = await PatientService.GetByIdAsync(PatientIdQuery.Value);
                if (patient is not null)
                {
                    form.PatientId = patient.Id;
                    patientSearchTerm = patient.FullName;
                    patientSelected = true;
                }
            }
            if (DoctorIdQuery.HasValue)
                form.DoctorId = DoctorIdQuery.Value.ToString();
            if (!string.IsNullOrEmpty(NotesQuery))
                form.Notes = NotesQuery;
        }
    }

    private async Task SearchPatients()
    {
        patientSelected = false;
        if (patientSearchTerm.Length < 2) { patientResults = null; return; }

        patientResults = await PatientService.SearchAsync(new PatientSearchDto
        {
            SearchTerm = patientSearchTerm,
            Page = 1,
            PageSize = 8
        });
    }

    private void SelectPatient(PatientListItemDto patient)
    {
        form.PatientId = patient.Id;
        patientSearchTerm = patient.FullName;
        patientSelected = true;
        patientResults = null;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        if (form.PatientId == Guid.Empty)
        {
            errorMessage = "Bitte wählen Sie einen Patienten aus.";
            saving = false;
            return;
        }

        if (!Guid.TryParse(form.DoctorId, out var doctorId) || doctorId == Guid.Empty)
        {
            errorMessage = "Bitte wählen Sie einen Arzt aus.";
            saving = false;
            return;
        }

        if (!TimeOnly.TryParse(form.Time, out var time))
        {
            errorMessage = "Bitte geben Sie eine gültige Uhrzeit ein (z.B. 08:00).";
            saving = false;
            return;
        }

        try
        {
            var localDateTime = new DateTime(form.Date.Year, form.Date.Month, form.Date.Day, time.Hour, time.Minute, 0, DateTimeKind.Unspecified);
            var startTime = TimeZoneInfo.ConvertTimeToUtc(localDateTime, berlinTz);

            Guid appointmentId;

            if (IsEdit)
            {
                await AppointmentService.UpdateAsync(Id!.Value, new UpdateAppointmentDto
                {
                    PatientId = form.PatientId,
                    DoctorId = doctorId,
                    StartTime = startTime,
                    DurationMinutes = form.DurationMinutes,
                    AppointmentType = string.IsNullOrEmpty(selectedTemplate) ? null : selectedTemplate,
                    Notes = form.Notes
                });
                appointmentId = Id!.Value;
            }
            else
            {
                var created = await AppointmentService.CreateAsync(new CreateAppointmentDto
                {
                    PatientId = form.PatientId,
                    DoctorId = doctorId,
                    StartTime = startTime,
                    DurationMinutes = form.DurationMinutes,
                    AppointmentType = string.IsNullOrEmpty(selectedTemplate) ? null : selectedTemplate,
                    Notes = form.Notes
                });
                appointmentId = created.Id;
            }

            // Navigate to calendar filtered by doctor, week of the appointment, highlighted
            // Preserve the view mode from the original return URL
            var targetDate = form.Date;
            var monday = targetDate.AddDays(-(((int)targetDate.DayOfWeek + 6) % 7));
            var ansicht = ExtractQueryParam(ReturnUrl, "ansicht") ?? "kalender";
            Navigation.NavigateTo($"/termine?arzt={doctorId}&highlight={appointmentId}&woche={monday:yyyy-MM-dd}&ansicht={ansicht}&datum={targetDate:yyyy-MM-dd}", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            saving = false;
        }
    }

    private void ApplyTemplate()
    {
        var template = AppointmentTypeCatalog.GetByName(selectedTemplate);
        if (template is not null)
            form.DurationMinutes = template.DefaultDurationMinutes;
    }

    // Slot suggestion
    private string preferredDay = string.Empty;
    private string preferredTimeStr = string.Empty;
    private bool searchingSlots;
    private IReadOnlyList<FreeSlotDto>? suggestedSlots;
    private string? slotError;

    private async Task SearchSlots()
    {
        slotError = null;
        suggestedSlots = null;

        if (!Guid.TryParse(form.DoctorId, out var doctorId) || doctorId == Guid.Empty)
        {
            slotError = "Bitte zuerst einen Arzt wählen.";
            return;
        }

        searchingSlots = true;
        try
        {
            // Check if doctor has any schedule configured
            var schedule = await AvailabilityService.GetScheduleAsync(doctorId);
            if (schedule.Count == 0)
            {
                slotError = "Dieser Arzt hat keine Sprechzeiten konfiguriert. Bitte unter Verwaltung → Sprechzeiten einrichten.";
                searchingSlots = false;
                return;
            }

            DayOfWeek? prefDay = !string.IsNullOrEmpty(preferredDay) ? (DayOfWeek)int.Parse(preferredDay) : null;
            TimeOnly? prefTime = TimeOnly.TryParse(preferredTimeStr, out var t) ? t : null;

            suggestedSlots = await SlotSuggestionService.SuggestNextSlotAsync(
                doctorId, form.DurationMinutes, prefDay, prefTime);

            if (suggestedSlots.Count == 0)
                slotError = "Keine freien Slots in den nächsten 8 Wochen gefunden.";
        }
        catch
        {
            slotError = "Fehler bei der Slot-Suche.";
        }
        finally
        {
            searchingSlots = false;
        }
    }

    private void ApplySlot(FreeSlotDto slot)
    {
        var local = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(slot.Start, DateTimeKind.Utc), berlinTz);
        form.Date = DateOnly.FromDateTime(local);
        form.Time = local.ToString("HH:mm");
        form.DurationMinutes = slot.DurationMinutes;
        suggestedSlots = null;
    }

    private static string? ExtractQueryParam(string? url, string key)
    {
        if (string.IsNullOrEmpty(url)) return null;
        var decoded = Uri.UnescapeDataString(url);
        var qIndex = decoded.IndexOf('?');
        if (qIndex < 0) return null;
        var query = decoded[(qIndex + 1)..];
        foreach (var part in query.Split('&'))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && kv[0].Equals(key, StringComparison.OrdinalIgnoreCase))
                return kv[1];
        }
        return null;
    }

    private class AppointmentFormModel
    {
        public Guid PatientId { get; set; }
        public string DoctorId { get; set; } = string.Empty;
        public DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string Time { get; set; } = "08:00";
        public int DurationMinutes { get; set; } = 10;
        public string? Notes { get; set; }
    }
}
