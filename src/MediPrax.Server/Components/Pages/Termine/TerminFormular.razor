@page "/termine/neu"
@page "/termine/{Id:guid}"
@attribute [Authorize]
@inject IAppointmentService AppointmentService
@inject IPatientService PatientService
@inject IUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(IsEdit ? "Termin bearbeiten" : "Neuer Termin")</PageTitle>

<div class="page-header">
    <h1>@(IsEdit ? "Termin bearbeiten" : "Neuer Termin")</h1>
</div>

@if (notFound)
{
    <p>Termin nicht gefunden.</p>
}
else
{
    <div class="form-container">
        <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="appointmentForm">
            <fieldset>
                <legend>Termin</legend>

                <div class="form-row">
                    <div class="form-group">
                        <label>Patient *</label>
                        <div class="patient-search">
                            <input type="text"
                                   @bind="patientSearchTerm"
                                   @bind:event="oninput"
                                   @bind:after="SearchPatients"
                                   placeholder="Patient suchen..."
                                   class="form-control" />
                            @if (patientResults is not null && patientResults.Items.Count > 0 && !patientSelected)
                            {
                                <div class="search-dropdown">
                                    @foreach (var p in patientResults.Items)
                                    {
                                        <div class="search-item" @onclick="() => SelectPatient(p)">
                                            <span class="item-name">@p.FullName</span>
                                            <span class="item-detail">@p.DateOfBirth.ToString("dd.MM.yyyy")</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Arzt *</label>
                        <InputSelect @bind-Value="form.DoctorId" class="form-control">
                            <option value="">— Arzt wählen —</option>
                            @foreach (var doc in doctors)
                            {
                                <option value="@doc.Id">@doc.FullName</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Terminart</label>
                        <select class="form-control" @bind="selectedTemplate" @bind:after="ApplyTemplate">
                            <option value="">— Freitext —</option>
                            @foreach (var t in appointmentTemplates)
                            {
                                <option value="@t.Name">@t.Name (@t.DefaultDurationMinutes Min.)</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Datum *</label>
                        <InputDate @bind-Value="form.Date" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Uhrzeit *</label>
                        <InputText @bind-Value="form.Time" class="form-control" placeholder="08:00" />
                    </div>
                    <div class="form-group" style="flex: 0.5">
                        <label>Dauer (Min.)</label>
                        <InputNumber @bind-Value="form.DurationMinutes" class="form-control" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group full">
                        <label>Notizen</label>
                        <InputTextArea @bind-Value="form.Notes" class="form-control" rows="2" />
                    </div>
                </div>
            </fieldset>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "Speichern..." : IsEdit ? "Speichern" : "Termin anlegen")
                </button>
                <a href="/termine" class="btn btn-secondary">Abbrechen</a>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery] public Guid? PatientIdQuery { get; set; }
    [SupplyParameterFromQuery] public Guid? DoctorIdQuery { get; set; }
    [SupplyParameterFromQuery] public string? NotesQuery { get; set; }

    private bool IsEdit => Id.HasValue;
    private bool notFound;
    private AppointmentFormModel form = new();
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private IReadOnlyList<AppointmentTypeTemplate> appointmentTemplates = AppointmentTypeCatalog.AllTemplates;
    private string selectedTemplate = string.Empty;
    private PagedResult<PatientListItemDto>? patientResults;
    private string patientSearchTerm = string.Empty;
    private bool patientSelected;
    private bool saving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        doctors = await UserService.GetDoctorsAsync();

        if (IsEdit)
        {
            var appointment = await AppointmentService.GetByIdAsync(Id!.Value);
            if (appointment is null)
            {
                notFound = true;
                return;
            }

            form.PatientId = appointment.PatientId;
            form.DoctorId = appointment.DoctorId.ToString();
            form.Date = DateOnly.FromDateTime(appointment.StartTime);
            form.Time = appointment.StartTime.ToString("HH:mm");
            form.DurationMinutes = appointment.DurationMinutes;
            form.Notes = appointment.Notes;
            patientSearchTerm = appointment.PatientName;
            patientSelected = true;
        }
        else
        {
            // Pre-fill from query parameters (e.g. from Warteliste)
            if (PatientIdQuery.HasValue)
            {
                var patient = await PatientService.GetByIdAsync(PatientIdQuery.Value);
                if (patient is not null)
                {
                    form.PatientId = patient.Id;
                    patientSearchTerm = patient.FullName;
                    patientSelected = true;
                }
            }
            if (DoctorIdQuery.HasValue)
                form.DoctorId = DoctorIdQuery.Value.ToString();
            if (!string.IsNullOrEmpty(NotesQuery))
                form.Notes = NotesQuery;
        }
    }

    private async Task SearchPatients()
    {
        patientSelected = false;
        if (patientSearchTerm.Length < 2) { patientResults = null; return; }

        patientResults = await PatientService.SearchAsync(new PatientSearchDto
        {
            SearchTerm = patientSearchTerm,
            Page = 1,
            PageSize = 8
        });
    }

    private void SelectPatient(PatientListItemDto patient)
    {
        form.PatientId = patient.Id;
        patientSearchTerm = patient.FullName;
        patientSelected = true;
        patientResults = null;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        if (form.PatientId == Guid.Empty)
        {
            errorMessage = "Bitte wählen Sie einen Patienten aus.";
            saving = false;
            return;
        }

        if (!Guid.TryParse(form.DoctorId, out var doctorId) || doctorId == Guid.Empty)
        {
            errorMessage = "Bitte wählen Sie einen Arzt aus.";
            saving = false;
            return;
        }

        if (!TimeOnly.TryParse(form.Time, out var time))
        {
            errorMessage = "Bitte geben Sie eine gültige Uhrzeit ein (z.B. 08:00).";
            saving = false;
            return;
        }

        try
        {
            var startTime = form.Date.ToDateTime(time, DateTimeKind.Utc);

            if (IsEdit)
            {
                await AppointmentService.UpdateAsync(Id!.Value, new UpdateAppointmentDto
                {
                    PatientId = form.PatientId,
                    DoctorId = doctorId,
                    StartTime = startTime,
                    DurationMinutes = form.DurationMinutes,
                    Notes = form.Notes
                });
            }
            else
            {
                await AppointmentService.CreateAsync(new CreateAppointmentDto
                {
                    PatientId = form.PatientId,
                    DoctorId = doctorId,
                    StartTime = startTime,
                    DurationMinutes = form.DurationMinutes,
                    Notes = form.Notes
                });
            }

            Navigation.NavigateTo("/termine");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            saving = false;
        }
    }

    private void ApplyTemplate()
    {
        var template = AppointmentTypeCatalog.GetByName(selectedTemplate);
        if (template is not null)
            form.DurationMinutes = template.DefaultDurationMinutes;
    }

    private class AppointmentFormModel
    {
        public Guid PatientId { get; set; }
        public string DoctorId { get; set; } = string.Empty;
        public DateOnly Date { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string Time { get; set; } = "08:00";
        public int DurationMinutes { get; set; } = 10;
        public string? Notes { get; set; }
    }
}
