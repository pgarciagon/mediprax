@page "/"
@attribute [Authorize]
@inject IDashboardService DashboardService
@inject IAppointmentService AppointmentService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@using System.Security.Claims
@using MediPrax.Core.Enums

<PageTitle>MediPrax — Dashboard</PageTitle>

@if (data is null)
{
    <p>Laden...</p>
}
else
{
    <div class="dashboard-header">
        <div>
            <h1>Dashboard</h1>
            <AuthorizeView Roles="Arzt"><Authorized><span class="role-subtitle">Arzt-Cockpit</span></Authorized></AuthorizeView>
            <AuthorizeView Roles="MFA"><Authorized><span class="role-subtitle">Praxis-Assistenz</span></Authorized></AuthorizeView>
            <AuthorizeView Roles="Empfang"><Authorized><span class="role-subtitle">Empfang &amp; Anmeldung</span></Authorized></AuthorizeView>
            <AuthorizeView Roles="Admin"><Authorized><span class="role-subtitle">Praxisverwaltung</span></Authorized></AuthorizeView>
        </div>
        <span class="date-label">@DateTime.Today.ToString("dddd, dd. MMMM yyyy", new System.Globalization.CultureInfo("de-DE"))</span>
    </div>

    @* === SHARED KPIs === *@
    <div class="kpi-grid">
        <div class="kpi-card accent">
            <span class="kpi-value">@data.AppointmentsToday</span>
            <span class="kpi-label">Termine heute</span>
            <a href="/termine" class="kpi-link">Kalender</a>
        </div>
        <AuthorizeView Roles="Arzt,Admin">
            <Authorized>
                <div class="kpi-card @(data.OpenArztbriefe > 0 ? "warn" : "")">
                    <span class="kpi-value">@data.OpenArztbriefe</span>
                    <span class="kpi-label">Offene Arztbriefe</span>
                </div>
                <div class="kpi-card @(data.OverdueRecalls > 0 ? "warn" : "")">
                    <span class="kpi-value">@data.DueRecalls</span>
                    <span class="kpi-label">Wiedervorlagen fällig</span>
                    @if (data.OverdueRecalls > 0) { <span class="kpi-sub">@data.OverdueRecalls überfällig</span> }
                    <a href="/wiedervorlagen" class="kpi-link">Alle anzeigen</a>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="MFA,Empfang,Admin">
            <Authorized>
                <div class="kpi-card">
                    <span class="kpi-value">@data.WaitingRoomCount</span>
                    <span class="kpi-label">Im Wartezimmer</span>
                    @if (data.InTreatmentCount > 0) { <span class="kpi-sub">@data.InTreatmentCount in Behandlung</span> }
                    <a href="/wartezimmer" class="kpi-link">Wartezimmer</a>
                </div>
                <div class="kpi-card @(data.WaitlistUrgent > 0 ? "warn" : "")">
                    <span class="kpi-value">@data.WaitlistTotal</span>
                    <span class="kpi-label">Warteliste</span>
                    @if (data.WaitlistUrgent > 0) { <span class="kpi-sub">@data.WaitlistUrgent dringend · Ø @data.WaitlistAvgDays.ToString("F0") Tage</span> }
                    <a href="/warteliste" class="kpi-link">Warteliste</a>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="kpi-card @(data.OverdueInvoices > 0 ? "warn" : "")">
                    <span class="kpi-value">@data.OpenInvoices</span>
                    <span class="kpi-label">Offene Rechnungen</span>
                    @if (data.OpenInvoiceAmount > 0) { <span class="kpi-sub">@data.OpenInvoiceAmount.ToString("N0") € · @data.OverdueInvoices überfällig</span> }
                </div>
                <div class="kpi-card">
                    <span class="kpi-value">@data.TotalPatients</span>
                    <span class="kpi-label">Patienten gesamt</span>
                    <a href="/patienten" class="kpi-link">Alle anzeigen</a>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @* === WARNINGS (Arzt + Admin) === *@
    <AuthorizeView Roles="Arzt,Admin">
        <Authorized>
            @if (data.Warnings.Count > 0)
            {
                <div class="dashboard-warnings">
                    @foreach (var w in data.Warnings)
                    {
                        <div class="warning-row level-@w.Level">
                            <span class="warning-icon">@(w.Level == "danger" ? "!" : "⚠")</span>
                            <div class="warning-content">
                                @if (w.PatientId.HasValue)
                                {
                                    <a href="/patienten/@w.PatientId"><strong>@w.PatientName</strong></a>
                                }
                                <span>@w.Message</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </Authorized>
    </AuthorizeView>

    <div class="dashboard-grid">
        @* === TERMINE HEUTE === *@
        <section class="dashboard-card">
            <h2>Termine heute</h2>
            @{
                var sortedAppts = data.UpcomingAppointments
                    .OrderBy(a => a.Status == AppointmentStatus.InProgress ? 0 :
                                  a.Status == AppointmentStatus.CheckedIn ? 1 :
                                  a.Status == AppointmentStatus.Scheduled ? 2 : 3)
                    .ThenBy(a => a.StartTime).ToList();
            }
            @if (sortedAppts.Count == 0)
            {
                <p class="empty">Keine Termine heute.</p>
            }
            else
            {
                <div class="appointment-list">
                    @foreach (var appt in sortedAppts)
                    {
                        <div class="appt-row status-@appt.Status.ToString().ToLower()">
                            <a href="/termine/@appt.Id" class="appt-time">@appt.StartTime.ToLocalTime().ToString("HH:mm")</a>
                            <a href="/patienten/@appt.PatientId" class="appt-patient">@appt.PatientName</a>
                            @if (!string.IsNullOrEmpty(appt.AppointmentType))
                            {
                                <span class="appt-type">@appt.AppointmentType</span>
                            }
                            @if (appt.Status == AppointmentStatus.Scheduled)
                            {
                                <span class="appt-status" style="cursor:pointer;" @onclick="() => CheckInAndGoToWartezimmer(appt.Id)">Erwartet</span>
                            }
                            else
                            {
                                <span class="appt-status">@StatusLabel(appt.Status)</span>
                            }
                            @if (appt.Status == AppointmentStatus.CheckedIn)
                            {
                                <a href="/patienten/@appt.PatientId/dokumentation/neu?DoctorIdQuery=@appt.DoctorId&DurationQuery=@appt.DurationMinutes&AppointmentIdQuery=@appt.Id"
                                   style="display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:4px;background:#059669;color:#fff;font-size:0.72rem;font-weight:700;text-decoration:none;flex-shrink:0;"
                                   title="Konsultation starten">K</a>
                            }
                        </div>
                    }
                </div>
            }
        </section>

        @* === RECENT ACTIVITY === *@
        <section class="dashboard-card">
            <h2>Letzte Aktivität</h2>
            @if (data.RecentActivity.Count == 0)
            {
                <p class="empty">Keine Aktivität.</p>
            }
            else
            {
                <div class="activity-list">
                    @foreach (var act in data.RecentActivity)
                    {
                        <div class="activity-row">
                            <span class="activity-icon type-@act.Type">
                                @(act.Type == "encounter" ? "K" : "B")
                            </span>
                            <div class="activity-info">
                                @if (act.PatientId.HasValue)
                                {
                                    <a href="/patienten/@act.PatientId">@act.Description</a>
                                }
                                else
                                {
                                    <span>@act.Description</span>
                                }
                                <span class="activity-time">@FormatTimeAgo(act.Timestamp)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    @* === MFA: MISSING DATA === *@
    <AuthorizeView Roles="MFA,Admin">
        <Authorized>
            @if (data.PatientsWithMissingData > 0)
            {
                <div class="dashboard-info">
                    <span style="font-size:0.82rem;color:var(--color-text-secondary);">
                        <strong>@data.PatientsWithMissingData</strong> Patienten mit fehlenden Stammdaten (KVNR oder Krankenkasse)
                    </span>
                </div>
            }
        </Authorized>
    </AuthorizeView>

    @* === QUICK ACTIONS (role-adaptive) === *@
    <div class="quick-actions">
        <AuthorizeView Roles="MFA,Empfang,Admin">
            <Authorized>
                <a href="/patienten/neu" class="action-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                    <span class="action-title">Neuer Patient</span>
                </a>
            </Authorized>
        </AuthorizeView>
        <a href="/termine/neu" class="action-card">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/></svg>
            <span class="action-title">Neuer Termin</span>
        </a>
        <a href="/termine" class="action-card">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span class="action-title">Kalender</span>
        </a>
        <a href="/wartezimmer" class="action-card">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="action-title">Wartezimmer</span>
        </a>
        <AuthorizeView Roles="Arzt">
            <Authorized>
                <a href="/wiedervorlagen" class="action-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><circle cx="12" cy="12" r="4"/></svg>
                    <span class="action-title">Wiedervorlagen</span>
                </a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="MFA,Empfang,Admin">
            <Authorized>
                <a href="/warteliste" class="action-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    <span class="action-title">Warteliste</span>
                </a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <a href="/abrechnung" class="action-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="10" y1="3" x2="10" y2="21"/></svg>
                    <span class="action-title">Abrechnung</span>
                </a>
                <a href="/verwaltung/sprechzeiten" class="action-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 8 14"/><path d="M17 12h4"/></svg>
                    <span class="action-title">Sprechzeiten</span>
                </a>
            </Authorized>
        </AuthorizeView>
    </div>
}

@code {
    private DashboardDto? data;
    private Guid? currentUserId;
    private UserRole? currentRole;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var auth = await AuthState;
            var idClaim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (idClaim is not null) currentUserId = Guid.Parse(idClaim);
            var roleClaim = auth.User.FindFirst(ClaimTypes.Role)?.Value;
            if (roleClaim is not null && Enum.TryParse<UserRole>(roleClaim, out var r)) currentRole = r;
        }

        data = await DashboardService.GetDashboardAsync(currentUserId, currentRole);
    }

    private async Task CheckInAndGoToWartezimmer(Guid appointmentId)
    {
        await AppointmentService.UpdateStatusAsync(appointmentId, AppointmentStatus.CheckedIn);
        Navigation.NavigateTo($"/wartezimmer?highlight={appointmentId}");
    }

    private static string StatusLabel(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Scheduled => "Erwartet",
        AppointmentStatus.CheckedIn => "Wartezimmer",
        AppointmentStatus.InProgress => "In Behandlung",
        AppointmentStatus.Completed => "Fertig",
        _ => s.ToString()
    };

    private static string FormatTimeAgo(DateTime ts)
    {
        var diff = DateTime.UtcNow - ts;
        if (diff.TotalMinutes < 60) return $"vor {(int)diff.TotalMinutes} Min.";
        if (diff.TotalHours < 24) return $"vor {(int)diff.TotalHours} Std.";
        return ts.ToLocalTime().ToString("dd.MM.yyyy");
    }
}
