@page "/labor"
@attribute [Authorize(Policy = "Klinisch")]
@inject ILabResultService LabResultService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Laborübersicht</PageTitle>

<div class="page-header">
    <h1>Laborübersicht</h1>
</div>

@if (results is null)
{
    <p>Laden...</p>
}
else if (results.Count == 0)
{
    <div class="empty-state">
        <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 3h6l1 7H8L9 3z"/><path d="M8 10v10a2 2 0 002 2h4a2 2 0 002-2V10"/><line x1="12" y1="14" x2="12" y2="18"/>
        </svg>
        <p>Keine offenen Laboranforderungen.</p>
    </div>
}
else
{
    <div class="lab-summary">
        <div class="summary-card">
            <span class="summary-value">@results.Count(r => r.Status == LabResultStatus.Ordered)</span>
            <span class="summary-label">Angefordert</span>
        </div>
        <div class="summary-card warning">
            <span class="summary-value">@results.Count(r => r.Status == LabResultStatus.Received)</span>
            <span class="summary-label">Eingegangen (ungelesen)</span>
        </div>
        <div class="summary-card danger">
            <span class="summary-value">@results.Count(r => r.HasCriticalValues)</span>
            <span class="summary-label">Kritische Werte</span>
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Anforderung</th>
                <th>Ergebnis</th>
                <th>Labor</th>
                <th>Status</th>
                <th>Werte</th>
                <th>Auffällig</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in results)
            {
                <tr>
                    <td><a href="/patienten/@r.PatientId">@r.PatientName</a></td>
                    <td>@r.OrderDate.ToString("dd.MM.yyyy")</td>
                    <td>@(r.ResultDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@r.LabName</td>
                    <td>
                        <span class="status-badge status-@r.Status.ToString().ToLower()">@r.StatusDisplay</span>
                    </td>
                    <td>@r.ValueCount</td>
                    <td>
                        @if (r.HasCriticalValues)
                        {
                            <span class="flag-critical">Kritisch</span>
                        }
                        else if (r.HasAbnormalValues)
                        {
                            <span class="flag-abnormal">Auffällig</span>
                        }
                        else if (r.ValueCount > 0)
                        {
                            <span class="flag-normal">Normal</span>
                        }
                    </td>
                    <td>
                        <a href="/labor/@r.PatientId" class="btn btn-sm btn-secondary">Öffnen</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<LabResultListItemDto>? results;

    protected override async Task OnInitializedAsync()
    {
        results = await LabResultService.GetActionRequiredAsync();
    }
}
