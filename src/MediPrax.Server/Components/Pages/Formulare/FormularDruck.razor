@page "/patienten/{PatientId:guid}/formulare"
@attribute [Authorize(Policy = "Klinisch")]
@inject IPatientService PatientService
@inject IUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Formulare drucken</PageTitle>

<div class="page-header">
    <h1>Formulare</h1>
    @if (patient is not null) { <span class="patient-context">@patient.FullName</span> }
</div>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <div class="form-cards">
        <div class="form-card" @onclick='() => activeForm = "rezept"'>
            <h3>Rezept</h3>
            <p>Kassenrezept / Privatrezept</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "ueberweisung"'>
            <h3>Überweisung</h3>
            <p>Muster 6</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "au"'>
            <h3>AU-Bescheinigung</h3>
            <p>Muster 1</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "krankenhaus"'>
            <h3>Krankenhauseinweisung</h3>
            <p>Muster 2</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "heilmittel"'>
            <h3>Heilmittelverordnung</h3>
            <p>Muster 13</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "hkp"'>
            <h3>Häusliche Krankenpflege</h3>
            <p>Muster 12</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "soziotherapie"'>
            <h3>Soziotherapie</h3>
            <p>Muster 26</p>
        </div>
        <div class="form-card" @onclick='() => activeForm = "ueberweisungpt"' style="border-left: 4px solid #9c27b0;">
            <h3>Überweisung Psychotherapie</h3>
            <p>Muster 7</p>
        </div>
    </div>

    @if (activeForm == "rezept")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Rezept</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Medikament *</label>
                        <InputText @bind-Value="rezept.Medikament" class="form-control" placeholder="z.B. Sertralin 50mg N3" />
                    </div>
                    <div class="form-group" style="flex:0.4">
                        <label>PZN</label>
                        <InputText @bind-Value="rezept.Pzn" class="form-control" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Dosierung</label>
                        <InputText @bind-Value="rezept.Dosierung" class="form-control" placeholder="z.B. 1-0-0-0" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>Menge</label>
                        <InputNumber @bind-Value="rezept.Menge" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.4">
                        <label>Typ</label>
                        <select @bind="rezept.IsPrivat" class="form-control">
                            <option value="false">Kassenrezept</option>
                            <option value="true">Privatrezept</option>
                        </select>
                    </div>
                </div>
                <button class="btn btn-primary" @onclick="GenerateRezept">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "ueberweisung")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Überweisung</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>An Fachrichtung *</label>
                        <InputText @bind-Value="ueberweisung.AnFachrichtung" class="form-control" placeholder="z.B. Radiologie" />
                    </div>
                    <div class="form-group">
                        <label>An Arzt (optional)</label>
                        <InputText @bind-Value="ueberweisung.AnArzt" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Diagnose / Verdacht *</label>
                    <InputText @bind-Value="ueberweisung.Diagnose" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Fragestellung</label>
                    <InputTextArea @bind-Value="ueberweisung.Fragestellung" class="form-control" rows="2" />
                </div>
                <button class="btn btn-primary" @onclick="GenerateUeberweisung">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "au")
    {
        <div class="detail-form">
            <fieldset>
                <legend>AU-Bescheinigung</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Von *</label>
                        <InputDate @bind-Value="au.Von" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Bis *</label>
                        <InputDate @bind-Value="au.Bis" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Art</label>
                        <select @bind="au.Erst" class="form-control">
                            <option value="true">Erstbescheinigung</option>
                            <option value="false">Folgebescheinigung</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Diagnose *</label>
                        <InputText @bind-Value="au.Diagnose" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="au.IcdCode" class="form-control" placeholder="z.B. F32.1" />
                    </div>
                </div>
                <button class="btn btn-primary" @onclick="GenerateAu">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "krankenhaus")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Krankenhauseinweisung (Muster 2)</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Krankenhaus *</label>
                        <InputText @bind-Value="krankenhaus.Krankenhaus" class="form-control" placeholder="z.B. Klinikum Bremen-Mitte" />
                    </div>
                    <div class="form-group">
                        <label>Fachabteilung *</label>
                        <InputText @bind-Value="krankenhaus.Fachabteilung" class="form-control" placeholder="z.B. Psychiatrie" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Einweisungsdiagnose *</label>
                        <InputText @bind-Value="krankenhaus.Diagnose" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="krankenhaus.IcdCode" class="form-control" placeholder="z.B. F20.0" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Befunde / Begründung</label>
                    <InputTextArea @bind-Value="krankenhaus.Befunde" class="form-control" rows="2" />
                </div>
                <div class="form-group" style="flex:0.3">
                    <label>
                        <InputCheckbox @bind-Value="krankenhaus.IsNotfall" /> Notfalleinweisung
                    </label>
                </div>
                <button class="btn btn-primary" @onclick="GenerateKrankenhaus">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "heilmittel")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Heilmittelverordnung (Muster 13)</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Heilmittel *</label>
                        <select @bind="heilmittel.HeilmittelTyp" class="form-control">
                            <option value="">— Bitte wählen —</option>
                            <option value="Ergotherapie">Ergotherapie</option>
                            <option value="Physiotherapie">Physiotherapie</option>
                            <option value="Logopädie">Logopädie</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex:0.5">
                        <label>Anzahl Sitzungen *</label>
                        <InputNumber @bind-Value="heilmittel.AnzahlSitzungen" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.5">
                        <label>Frequenz</label>
                        <InputText @bind-Value="heilmittel.Frequenz" class="form-control" placeholder="z.B. 2x wöchentlich" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Diagnose *</label>
                        <InputText @bind-Value="heilmittel.Diagnose" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="heilmittel.IcdCode" class="form-control" placeholder="z.B. G35" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Therapieziel</label>
                    <InputTextArea @bind-Value="heilmittel.Therapieziel" class="form-control" rows="2" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:0.4">
                        <label>
                            <InputCheckbox @bind-Value="heilmittel.IsErstverordnung" /> Erstverordnung
                        </label>
                    </div>
                    <div class="form-group" style="flex:0.4">
                        <label>
                            <InputCheckbox @bind-Value="heilmittel.IsHausbesuch" /> Hausbesuch
                        </label>
                    </div>
                </div>
                <button class="btn btn-primary" @onclick="GenerateHeilmittel">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "hkp")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Häusliche Krankenpflege (Muster 12)</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Diagnose *</label>
                        <InputText @bind-Value="hkp.Diagnose" class="form-control" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="hkp.IcdCode" class="form-control" placeholder="z.B. F20.0" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Verordnete Leistungen *</label>
                    <InputTextArea @bind-Value="hkp.Leistungen" class="form-control" rows="2" placeholder="z.B. Medikamentengabe, Verbandswechsel" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Von *</label>
                        <InputDate @bind-Value="hkp.Von" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Bis *</label>
                        <InputDate @bind-Value="hkp.Bis" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Frequenz</label>
                        <InputText @bind-Value="hkp.Frequenz" class="form-control" placeholder="z.B. täglich" />
                    </div>
                </div>
                <div class="form-group">
                    <label>
                        <InputCheckbox @bind-Value="hkp.IsPsychiatrisch" /> Psychiatrische häusliche Krankenpflege (§ 37 Abs. 2 SGB V)
                    </label>
                </div>
                <button class="btn btn-primary" @onclick="GenerateHkp">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "soziotherapie")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Soziotherapie (Muster 26)</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Diagnose *</label>
                        <InputText @bind-Value="sozio.Diagnose" class="form-control" placeholder="z.B. Paranoid-halluzinatorische Schizophrenie" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="sozio.IcdCode" class="form-control" placeholder="z.B. F20.0" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Fähigkeitsstörungen *</label>
                    <InputTextArea @bind-Value="sozio.Faehigkeitsstoerungen" class="form-control" rows="2" placeholder="Beschreiben Sie die bestehenden Fähigkeitsstörungen" />
                </div>
                <div class="form-group">
                    <label>Therapieziele *</label>
                    <InputTextArea @bind-Value="sozio.Therapieziele" class="form-control" rows="2" placeholder="Beschreiben Sie die Therapieziele" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:0.4">
                        <label>Verordnete Stunden * (max. 120)</label>
                        <InputNumber @bind-Value="sozio.Stunden" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Soziotherapeut / Leistungserbringer</label>
                        <InputText @bind-Value="sozio.Soziotherapeut" class="form-control" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Art</label>
                    <select @bind="sozio.Erst" class="form-control">
                        <option value="true">Erstverordnung</option>
                        <option value="false">Folgeverordnung</option>
                    </select>
                </div>
                <button class="btn btn-primary" @onclick="GenerateSoziotherapie">PDF erzeugen</button>
            </fieldset>
        </div>
    }

    @if (activeForm == "ueberweisungpt")
    {
        <div class="detail-form">
            <fieldset>
                <legend>Überweisung zur Psychotherapie (Muster 7)</legend>
                <div class="form-row">
                    <div class="form-group">
                        <label>Diagnose *</label>
                        <InputText @bind-Value="ueberweisungPt.Diagnose" class="form-control" placeholder="z.B. Mittelgradige depressive Episode" />
                    </div>
                    <div class="form-group" style="flex:0.3">
                        <label>ICD-10</label>
                        <InputText @bind-Value="ueberweisungPt.IcdCode" class="form-control" placeholder="z.B. F32.1" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Therapieverfahren *</label>
                    <select @bind="ueberweisungPt.TherapieForm" class="form-control">
                        <option value="">— Bitte wählen —</option>
                        <option value="Verhaltenstherapie">Verhaltenstherapie (VT)</option>
                        <option value="Tiefenpsychologisch fundierte Psychotherapie">Tiefenpsychologisch fundierte Psychotherapie (TP)</option>
                        <option value="Analytische Psychotherapie">Analytische Psychotherapie (AP)</option>
                        <option value="Systemische Therapie">Systemische Therapie (ST)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Relevante Befunde / Anamnese</label>
                    <InputTextArea @bind-Value="ueberweisungPt.Befunde" class="form-control" rows="2" placeholder="Zusammenfassung relevanter Befunde" />
                </div>
                <div class="form-group">
                    <label>
                        <InputCheckbox @bind-Value="ueberweisungPt.SomatischeAbklaerung" /> Somatische Abklärung erfolgt
                    </label>
                </div>
                @if (ueberweisungPt.SomatischeAbklaerung)
                {
                    <div class="form-group">
                        <label>Details zur somatischen Abklärung</label>
                        <InputText @bind-Value="ueberweisungPt.SomatischeAbklaerungDetails" class="form-control" placeholder="z.B. Labor unauffällig, Schilddrüse abgeklärt" />
                    </div>
                }
                <div class="form-group">
                    <label>
                        <InputCheckbox @bind-Value="ueberweisungPt.Dringlichkeit" /> Dringende Überweisung
                    </label>
                </div>
                <button class="btn btn-primary" @onclick="GenerateUeberweisungPt">PDF erzeugen</button>
            </fieldset>
        </div>
    }
}

@code {
    [Parameter] public Guid PatientId { get; set; }

    private PatientDto? patient;
    private string activeForm = "";

    private RezeptForm rezept = new();
    private UeberweisungForm ueberweisung = new();
    private AuForm au = new();
    private KrankenhausForm krankenhaus = new();
    private HeilmittelForm heilmittel = new();
    private HkpForm hkp = new();
    private SoziotherapieForm sozio = new();
    private UeberweisungPtForm ueberweisungPt = new();

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(PatientId);
        if (patient is null) Navigation.NavigateTo("/patienten");
    }

    private void GenerateRezept()
    {
        // In production: generate PDF and open in new tab
        // For now: navigate to a PDF endpoint (to be added)
        Navigation.NavigateTo($"/api/formulare/rezept?patientId={PatientId}&medikament={Uri.EscapeDataString(rezept.Medikament)}&dosierung={Uri.EscapeDataString(rezept.Dosierung ?? "")}&pzn={rezept.Pzn}&menge={rezept.Menge}&privat={rezept.IsPrivat}", forceLoad: true);
    }

    private void GenerateUeberweisung()
    {
        Navigation.NavigateTo($"/api/formulare/ueberweisung?patientId={PatientId}&fachrichtung={Uri.EscapeDataString(ueberweisung.AnFachrichtung)}&arzt={Uri.EscapeDataString(ueberweisung.AnArzt ?? "")}&diagnose={Uri.EscapeDataString(ueberweisung.Diagnose)}&frage={Uri.EscapeDataString(ueberweisung.Fragestellung ?? "")}", forceLoad: true);
    }

    private void GenerateAu()
    {
        Navigation.NavigateTo($"/api/formulare/au?patientId={PatientId}&von={au.Von:yyyy-MM-dd}&bis={au.Bis:yyyy-MM-dd}&erst={au.Erst}&diagnose={Uri.EscapeDataString(au.Diagnose)}&icd={Uri.EscapeDataString(au.IcdCode ?? "")}", forceLoad: true);
    }

    private void GenerateKrankenhaus()
    {
        Navigation.NavigateTo($"/api/formulare/krankenhauseinweisung?patientId={PatientId}&krankenhaus={Uri.EscapeDataString(krankenhaus.Krankenhaus)}&fachabteilung={Uri.EscapeDataString(krankenhaus.Fachabteilung)}&diagnose={Uri.EscapeDataString(krankenhaus.Diagnose)}&icd={Uri.EscapeDataString(krankenhaus.IcdCode ?? "")}&befunde={Uri.EscapeDataString(krankenhaus.Befunde ?? "")}&notfall={krankenhaus.IsNotfall}", forceLoad: true);
    }

    private void GenerateHeilmittel()
    {
        Navigation.NavigateTo($"/api/formulare/heilmittelverordnung?patientId={PatientId}&heilmittel={Uri.EscapeDataString(heilmittel.HeilmittelTyp)}&diagnose={Uri.EscapeDataString(heilmittel.Diagnose)}&icd={Uri.EscapeDataString(heilmittel.IcdCode ?? "")}&ziel={Uri.EscapeDataString(heilmittel.Therapieziel ?? "")}&sitzungen={heilmittel.AnzahlSitzungen}&frequenz={Uri.EscapeDataString(heilmittel.Frequenz ?? "")}&erst={heilmittel.IsErstverordnung}&hausbesuch={heilmittel.IsHausbesuch}", forceLoad: true);
    }

    private void GenerateHkp()
    {
        Navigation.NavigateTo($"/api/formulare/haeusliche-krankenpflege?patientId={PatientId}&diagnose={Uri.EscapeDataString(hkp.Diagnose)}&icd={Uri.EscapeDataString(hkp.IcdCode ?? "")}&leistungen={Uri.EscapeDataString(hkp.Leistungen)}&von={hkp.Von:yyyy-MM-dd}&bis={hkp.Bis:yyyy-MM-dd}&frequenz={Uri.EscapeDataString(hkp.Frequenz ?? "")}&psychiatrisch={hkp.IsPsychiatrisch}", forceLoad: true);
    }

    private void GenerateSoziotherapie()
    {
        Navigation.NavigateTo($"/api/formulare/soziotherapie?patientId={PatientId}&diagnose={Uri.EscapeDataString(sozio.Diagnose)}&icd={Uri.EscapeDataString(sozio.IcdCode ?? "")}&stoerungen={Uri.EscapeDataString(sozio.Faehigkeitsstoerungen)}&ziele={Uri.EscapeDataString(sozio.Therapieziele)}&stunden={sozio.Stunden}&therapeut={Uri.EscapeDataString(sozio.Soziotherapeut ?? "")}&erst={sozio.Erst}", forceLoad: true);
    }

    private void GenerateUeberweisungPt()
    {
        Navigation.NavigateTo($"/api/formulare/ueberweisung-psychotherapie?patientId={PatientId}&diagnose={Uri.EscapeDataString(ueberweisungPt.Diagnose)}&icd={Uri.EscapeDataString(ueberweisungPt.IcdCode ?? "")}&therapie={Uri.EscapeDataString(ueberweisungPt.TherapieForm)}&befunde={Uri.EscapeDataString(ueberweisungPt.Befunde ?? "")}&somatisch={ueberweisungPt.SomatischeAbklaerung}&somatischDetails={Uri.EscapeDataString(ueberweisungPt.SomatischeAbklaerungDetails ?? "")}&dringend={ueberweisungPt.Dringlichkeit}", forceLoad: true);
    }

    private class RezeptForm
    {
        public string Medikament { get; set; } = "";
        public string? Pzn { get; set; }
        public string? Dosierung { get; set; }
        public int Menge { get; set; } = 1;
        public bool IsPrivat { get; set; }
    }

    private class UeberweisungForm
    {
        public string AnFachrichtung { get; set; } = "";
        public string? AnArzt { get; set; }
        public string Diagnose { get; set; } = "";
        public string? Fragestellung { get; set; }
    }

    private class AuForm
    {
        public DateOnly Von { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public DateOnly Bis { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(7));
        public bool Erst { get; set; } = true;
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
    }

    private class KrankenhausForm
    {
        public string Krankenhaus { get; set; } = "";
        public string Fachabteilung { get; set; } = "";
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
        public string? Befunde { get; set; }
        public bool IsNotfall { get; set; }
    }

    private class HeilmittelForm
    {
        public string HeilmittelTyp { get; set; } = "";
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
        public string? Therapieziel { get; set; }
        public int AnzahlSitzungen { get; set; } = 10;
        public string? Frequenz { get; set; }
        public bool IsErstverordnung { get; set; } = true;
        public bool IsHausbesuch { get; set; }
    }

    private class HkpForm
    {
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
        public string Leistungen { get; set; } = "";
        public DateOnly Von { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public DateOnly Bis { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(14));
        public string? Frequenz { get; set; }
        public bool IsPsychiatrisch { get; set; }
    }

    private class SoziotherapieForm
    {
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
        public string Faehigkeitsstoerungen { get; set; } = "";
        public string Therapieziele { get; set; } = "";
        public int Stunden { get; set; } = 30;
        public string? Soziotherapeut { get; set; }
        public bool Erst { get; set; } = true;
    }

    private class UeberweisungPtForm
    {
        public string Diagnose { get; set; } = "";
        public string? IcdCode { get; set; }
        public string TherapieForm { get; set; } = "";
        public string? Befunde { get; set; }
        public bool SomatischeAbklaerung { get; set; }
        public string? SomatischeAbklaerungDetails { get; set; }
        public bool Dringlichkeit { get; set; }
    }
}
