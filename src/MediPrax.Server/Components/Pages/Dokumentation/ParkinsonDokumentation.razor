@page "/patienten/{PatientId:guid}/parkinson-dokumentation"
@attribute [Authorize(Policy = "Klinisch")]
@inject IParkinsonDocumentationService ParkinsonService
@inject IPatientService PatientService
@rendermode InteractiveServer

<PageTitle>Parkinson — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <SuicidalityAlert PatientId="PatientId" />

    <div class="page-header">
        <div>
            <a href="/patienten/@PatientId" class="back-link">&larr; @patient.FullName</a>
            <h1>Parkinson-Dokumentation</h1>
        </div>
        <button class="btn btn-primary btn-sm" @onclick="() => showForm = !showForm">+ Neue Dokumentation</button>
    </div>

    @if (showForm)
    {
        <div class="card form-card">
            <h3>Parkinson-Verlauf dokumentieren</h3>
            <div class="form-row">
                <div class="form-group">
                    <label>Datum *</label>
                    <input class="form-control" @bind="formDateStr" placeholder="2026-04-09" />
                </div>
                <div class="form-group" style="flex:0.5">
                    <label>Hoehn & Yahr (0–5) *</label>
                    <input type="number" class="form-control" @bind="form.HoehnYahrStage" min="0" max="5" step="0.5" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:0.5"><label>Tremor (0–4)</label><input type="number" class="form-control" @bind="form.Tremor" min="0" max="4" /></div>
                <div class="form-group" style="flex:0.5"><label>Rigor (0–4)</label><input type="number" class="form-control" @bind="form.Rigidity" min="0" max="4" /></div>
                <div class="form-group" style="flex:0.5"><label>Bradykinese (0–4)</label><input type="number" class="form-control" @bind="form.Bradykinesia" min="0" max="4" /></div>
                <div class="form-group" style="flex:0.5"><label>Post. Instab. (0–4)</label><input type="number" class="form-control" @bind="form.PosturalInstability" min="0" max="4" /></div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:0.3"><label><input type="checkbox" @bind="form.OnOffFluctuations" /> On/Off</label></div>
                <div class="form-group" style="flex:0.3"><label><input type="checkbox" @bind="form.Dyskinesia" /> Dyskinesien</label></div>
                <div class="form-group" style="flex:0.3"><label><input type="checkbox" @bind="form.FreezeOfGait" /> Freezing</label></div>
            </div>
            <div class="form-row">
                <div class="form-group full"><label>Anmerkungen</label><textarea class="form-control" @bind="form.Notes" rows="2"></textarea></div>
            </div>
            <div style="display:flex;gap:.5rem;margin-top:.5rem">
                <button class="btn btn-primary btn-sm" @onclick="Save">Speichern</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => showForm = false">Abbrechen</button>
            </div>
        </div>
    }

    @if (entries is not null && entries.Count > 0)
    {
        <div class="summary-cards" style="display:flex;gap:1rem;margin:1rem 0;">
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.1rem;font-weight:700;color:var(--color-primary)">@entries.First().HoehnYahrDisplay</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Aktuelles Stadium</div>
            </div>
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.First().MotorScore / 16</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Motor-Score</div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr><th>Datum</th><th>H&Y</th><th>Tremor</th><th>Rigor</th><th>Bradyk.</th><th>Instab.</th><th>On/Off</th><th>Dysk.</th><th>Freeze</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr>
                        <td>@e.DocumentationDate.ToString("dd.MM.yyyy")</td>
                        <td>@e.HoehnYahrStage.ToString("F1")</td>
                        <td>@e.Tremor</td>
                        <td>@e.Rigidity</td>
                        <td>@e.Bradykinesia</td>
                        <td>@e.PosturalInstability</td>
                        <td>@(e.OnOffFluctuations ? "Ja" : "—")</td>
                        <td>@(e.Dyskinesia ? "Ja" : "—")</td>
                        <td>@(e.FreezeOfGait ? "Ja" : "—")</td>
                        <td><button class="btn btn-sm btn-link danger" @onclick="() => Delete(e.Id)">Löschen</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (entries is not null)
    {
        <div class="empty-encounters">Noch keine Parkinson-Dokumentation vorhanden.</div>
    }
}

@code {
    [Parameter] public Guid PatientId { get; set; }
    private PatientDto? patient;
    private IReadOnlyList<ParkinsonDocumentationDto>? entries;
    private CreateParkinsonDocumentationDto form = new();
    private string formDateStr = DateTime.Today.ToString("yyyy-MM-dd");
    private bool showForm;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(PatientId);
        form.PatientId = PatientId;
        await LoadEntries();
    }

    private async Task LoadEntries() => entries = await ParkinsonService.GetByPatientAsync(PatientId);

    private async Task Save()
    {
        form.PatientId = PatientId;
        if (DateOnly.TryParse(formDateStr, out var d)) form.DocumentationDate = d;
        await ParkinsonService.CreateAsync(form);
        form = new() { PatientId = PatientId }; formDateStr = DateTime.Today.ToString("yyyy-MM-dd"); showForm = false;
        await LoadEntries();
    }

    private async Task Delete(Guid id) { await ParkinsonService.DeleteAsync(id); await LoadEntries(); }
}
