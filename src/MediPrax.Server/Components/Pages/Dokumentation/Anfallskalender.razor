@page "/patienten/{PatientId:guid}/anfallskalender"
@attribute [Authorize(Policy = "Klinisch")]
@inject ISeizureDiaryService SeizureDiaryService
@inject IPatientService PatientService
@rendermode InteractiveServer

<PageTitle>Anfallskalender — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <SuicidalityAlert PatientId="PatientId" />

    <div class="page-header">
        <div>
            <a href="/patienten/@PatientId" class="back-link">&larr; @patient.FullName</a>
            <h1>Anfallskalender</h1>
        </div>
        <button class="btn btn-primary btn-sm" @onclick="() => showForm = !showForm">+ Neuer Eintrag</button>
    </div>

    @if (showForm)
    {
        <div class="card form-card">
            <h3>Anfall dokumentieren</h3>
            <div class="form-row">
                <div class="form-group">
                    <label>Datum/Uhrzeit *</label>
                    <input class="form-control" @bind="form.SeizureDate" />
                </div>
                <div class="form-group">
                    <label>Anfallstyp *</label>
                    <select class="form-control" @bind="form.SeizureType">
                        <option value="Fokal">Fokal</option>
                        <option value="Generalisiert">Generalisiert</option>
                        <option value="Fokal zu bilateral tonisch-klonisch">Fokal zu bilateral t.-k.</option>
                        <option value="Unklassifiziert">Unklassifiziert</option>
                    </select>
                </div>
                <div class="form-group" style="flex:0.5">
                    <label>Dauer (Sek.)</label>
                    <input type="number" class="form-control" @bind="form.DurationSeconds" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Trigger</label>
                    <input class="form-control" @bind="form.Trigger" placeholder="z.B. Schlafmangel, Alkohol..." />
                </div>
                <div class="form-group" style="flex:0.4">
                    <label><input type="checkbox" @bind="form.AuraPresent" /> Aura</label>
                </div>
                <div class="form-group" style="flex:0.5">
                    <label><input type="checkbox" @bind="form.ConsciousnessImpaired" /> Bewusstseinsverlust</label>
                </div>
            </div>
            @if (form.AuraPresent)
            {
                <div class="form-row">
                    <div class="form-group full">
                        <label>Aura-Beschreibung</label>
                        <input class="form-control" @bind="form.AuraDescription" />
                    </div>
                </div>
            }
            <div class="form-row">
                <div class="form-group">
                    <label>Postiktaler Zustand</label>
                    <input class="form-control" @bind="form.PostictalState" placeholder="Verwirrtheit, Müdigkeit..." />
                </div>
                <div class="form-group">
                    <label>Aktuelle Medikation</label>
                    <input class="form-control" @bind="form.MedicationAtTime" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group full">
                    <label>Anmerkungen</label>
                    <textarea class="form-control" @bind="form.Notes" rows="2"></textarea>
                </div>
            </div>
            <div style="display:flex;gap:.5rem;margin-top:.5rem">
                <button class="btn btn-primary btn-sm" @onclick="Save">Speichern</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => showForm = false">Abbrechen</button>
            </div>
        </div>
    }

    @if (entries is not null && entries.Count > 0)
    {
        <div class="summary-cards" style="display:flex;gap:1rem;margin:1rem 0;">
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.Count</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Anfälle gesamt</div>
            </div>
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.Count(e => e.SeizureDate >= DateTime.UtcNow.AddDays(-30))</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Letzte 30 Tage</div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr><th>Datum</th><th>Typ</th><th>Dauer</th><th>Aura</th><th>Bewusstl.</th><th>Trigger</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var entry in entries)
                {
                    <tr>
                        <td>@entry.SeizureDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@entry.SeizureType</td>
                        <td>@entry.DurationDisplay</td>
                        <td>@(entry.AuraPresent ? "Ja" : "—")</td>
                        <td>@(entry.ConsciousnessImpaired ? "Ja" : "—")</td>
                        <td>@(entry.Trigger ?? "—")</td>
                        <td><button class="btn btn-sm btn-link danger" @onclick="() => Delete(entry.Id)">Löschen</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (entries is not null)
    {
        <div class="empty-encounters">Noch keine Anfälle dokumentiert.</div>
    }
}

@code {
    [Parameter] public Guid PatientId { get; set; }

    private PatientDto? patient;
    private IReadOnlyList<SeizureDiaryDto>? entries;
    private CreateSeizureDiaryDto form = new() { SeizureType = "Fokal" };
    private bool showForm;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(PatientId);
        form.PatientId = PatientId;
        form.SeizureDate = DateTime.Now;
        await LoadEntries();
    }

    private async Task LoadEntries() => entries = await SeizureDiaryService.GetByPatientAsync(PatientId);

    private async Task Save()
    {
        form.PatientId = PatientId;
        await SeizureDiaryService.CreateAsync(form);
        form = new() { PatientId = PatientId, SeizureType = "Fokal", SeizureDate = DateTime.Now };
        showForm = false;
        await LoadEntries();
    }

    private async Task Delete(Guid id)
    {
        await SeizureDiaryService.DeleteAsync(id);
        await LoadEntries();
    }
}
