@page "/patienten/{PatientId:guid}/anfallskalender"
@attribute [Authorize(Policy = "Klinisch")]
@inject ISeizureDiaryService SeizureDiaryService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Anfallskalender</PageTitle>

<div class="page-header">
    <h1>Anfallskalender</h1>
    <button class="btn btn-primary" @onclick="() => showForm = !showForm">+ Neuer Eintrag</button>
</div>

@if (showForm)
{
    <div class="card form-card">
        <h3>Anfall dokumentieren</h3>
        <div class="form-row">
            <div class="form-group">
                <label>Datum/Uhrzeit *</label>
                <input class="form-control" @bind="form.SeizureDate" />
            </div>
            <div class="form-group">
                <label>Anfallstyp *</label>
                <select class="form-control" @bind="form.SeizureType">
                    <option value="Fokal">Fokal</option>
                    <option value="Generalisiert">Generalisiert</option>
                    <option value="Fokal zu bilateral tonisch-klonisch">Fokal zu bilateral tonisch-klonisch</option>
                    <option value="Unklassifiziert">Unklassifiziert</option>
                </select>
            </div>
            <div class="form-group">
                <label>Dauer (Sekunden)</label>
                <input type="number" class="form-control" @bind="form.DurationSeconds" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Trigger</label>
                <input class="form-control" @bind="form.Trigger" placeholder="z.B. Schlafmangel, Alkohol..." />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="form.AuraPresent" /> Aura vorhanden
                </label>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="form.ConsciousnessImpaired" /> Bewusstseinsstörung
                </label>
            </div>
        </div>
        @if (form.AuraPresent)
        {
            <div class="form-row">
                <div class="form-group wide">
                    <label>Aura-Beschreibung</label>
                    <input class="form-control" @bind="form.AuraDescription" />
                </div>
            </div>
        }
        <div class="form-row">
            <div class="form-group">
                <label>Postiktaler Zustand</label>
                <input class="form-control" @bind="form.PostictalState" placeholder="z.B. Verwirrtheit, Müdigkeit..." />
            </div>
            <div class="form-group">
                <label>Aktuelle Medikation</label>
                <input class="form-control" @bind="form.MedicationAtTime" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group wide">
                <label>Anmerkungen</label>
                <textarea class="form-control" @bind="form.Notes" rows="2"></textarea>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="Save">Speichern</button>
            <button class="btn btn-secondary" @onclick="() => showForm = false">Abbrechen</button>
        </div>
    </div>
}

@if (entries is null)
{
    <p>Laden...</p>
}
else if (entries.Count == 0)
{
    <p class="empty-state">Noch keine Anfälle dokumentiert.</p>
}
else
{
    <div class="stats-row">
        <div class="stat-card">
            <span class="stat-value">@entries.Count</span>
            <span class="stat-label">Anfälle gesamt</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">@entries.Count(e => e.SeizureDate >= DateTime.UtcNow.AddDays(-30))</span>
            <span class="stat-label">Letzte 30 Tage</span>
        </div>
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th>Datum</th>
                <th>Typ</th>
                <th>Dauer</th>
                <th>Aura</th>
                <th>Bewusstlosigkeit</th>
                <th>Trigger</th>
                <th>Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in entries)
            {
                <tr>
                    <td>@entry.SeizureDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@entry.SeizureType</td>
                    <td>@entry.DurationDisplay</td>
                    <td>@(entry.AuraPresent ? "Ja" : "Nein")</td>
                    <td>@(entry.ConsciousnessImpaired ? "Ja" : "Nein")</td>
                    <td>@(entry.Trigger ?? "—")</td>
                    <td><button class="btn btn-sm btn-danger" @onclick="() => Delete(entry.Id)">Löschen</button></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public Guid PatientId { get; set; }

    private IReadOnlyList<SeizureDiaryDto>? entries;
    private CreateSeizureDiaryDto form = new() { SeizureType = "Fokal" };
    private bool showForm;

    protected override async Task OnInitializedAsync()
    {
        form.PatientId = PatientId;
        form.SeizureDate = DateTime.Now;
        await LoadEntries();
    }

    private async Task LoadEntries() => entries = await SeizureDiaryService.GetByPatientAsync(PatientId);

    private async Task Save()
    {
        form.PatientId = PatientId;
        await SeizureDiaryService.CreateAsync(form);
        form = new() { PatientId = PatientId, SeizureType = "Fokal", SeizureDate = DateTime.Now };
        showForm = false;
        await LoadEntries();
    }

    private async Task Delete(Guid id)
    {
        await SeizureDiaryService.DeleteAsync(id);
        await LoadEntries();
    }
}
