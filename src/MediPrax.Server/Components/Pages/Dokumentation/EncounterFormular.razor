    private async Task SaveAndNavigate(string befundType)
    {
        if (!Guid.TryParse(form.DoctorId, out var doctorId))
        {
            errorMessage = "Bitte wählen Sie einen Arzt.";
            return;
        }

        try
        {
            var created = await EncounterService.CreateAsync(new CreateEncounterDto
            {
                PatientId = PatientId!.Value,
                DoctorId = doctorId,
                AppointmentId = AppointmentIdQuery,
                EncounterDate = form.EncounterDate,
                Notes = null,
                Icd10Codes = form.Icd10Codes,
                DurationMinutes = form.DurationMinutes
            });
            var sectionDtos = BuildSectionDtos(doctorId);
            if (sectionDtos.Count > 0)
                await SectionService.SaveAllAsync(created.Id, sectionDtos);
            Navigation.NavigateTo($"/dokumentation/{befundType}/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        if (!Guid.TryParse(form.DoctorId, out var doctorId))
        {
            errorMessage = "Bitte wählen Sie einen Arzt.";
            saving = false;
            return;
        }

        try
        {
            var sectionDtos = BuildSectionDtos(doctorId);

            if (isEdit)
            {
                Enum.TryParse<EncounterStatus>(form.Status, out var status);
                var allCodes = BuildAllIcd10Codes();
                await EncounterService.UpdateAsync(new UpdateEncounterDto
                {
                    Id = Id!.Value,
                    PatientId = PatientId!.Value,
                    DoctorId = doctorId,
                    EncounterDate = form.EncounterDate,
                    Notes = hasLegacyNotes ? form.Notes : null,
                    Icd10Codes = allCodes,
                    DurationMinutes = form.DurationMinutes,
                    Status = status
                });
                await SectionService.SaveAllAsync(Id!.Value, sectionDtos);
            }
            else
            {
                var allCodes = BuildAllIcd10Codes();
                var created = await EncounterService.CreateAsync(new CreateEncounterDto
                {
                    PatientId = PatientId!.Value,
                    DoctorId = doctorId,
                    AppointmentId = AppointmentIdQuery,
                    EncounterDate = form.EncounterDate,
                    Notes = null,
                    Icd10Codes = allCodes,
                    DurationMinutes = form.DurationMinutes
                });
                await SectionService.SaveAllAsync(created.Id, sectionDtos);
                // Inherit Dauerdiagnosen to encounter (create EncounterDiagnosis links)
                await DiagnosisService.InheritDauerdiagnosenForEncounterAsync(created.Id);
            }

            Navigation.NavigateTo(backUrl);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            saving = false;
        }
    }

