@page "/patienten/{PatientId:guid}/dokumentation/neu"
@page "/dokumentation/{Id:guid}/bearbeiten"
@attribute [Authorize(Policy = "Klinisch")]
@inject IEncounterService EncounterService
@inject IPatientService PatientService
@inject IUserService UserService
@inject IBillingService BillingService
@inject IEncounterSectionService SectionService
@inject IPatientDiagnosisService DiagnosisService
@inject IIcd10CodeService Icd10Service
@inject IPsychopathFindingService PsychopathFindingService
@inject INeurologicalExamService NeuroExamService
@inject IActionChainService ActionChainService
@inject IActionChainExecutor ActionChainExecutor
@inject ICompositeBefundService CompositeBefundService
@inject NavigationManager Navigation
@rendermode InteractiveServer
@using System.Security.Claims
@using MediPrax.Application.DTOs
@using MediPrax.Core.Enums

<PageTitle>@(isEdit ? "Konsultation bearbeiten" : "Neue Konsultation")</PageTitle>

<div class="page-header">
    <h1>@(isEdit ? "Konsultation bearbeiten" : "Neue Konsultation")</h1>
    @if (patientName is not null)
    {
        <span class="patient-context">@patientName</span>
    }
</div>

@if (loading)
{
    <p>Laden...</p>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">@errorMessage</div>
    }

    <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="encounterForm">
        <fieldset>
            <legend>Konsultation</legend>

            <div class="form-row">
                <div class="form-group">
                    <label>Arzt *</label>
                    <InputSelect @bind-Value="form.DoctorId" class="form-control">
                        <option value="">— Arzt wählen —</option>
                        @foreach (var doc in doctors)
                        {
                            <option value="@doc.Id">@doc.FullName</option>
                        }
                    </InputSelect>
                </div>
                <div class="form-group">
                    <label>Datum</label>
                    <InputDate @bind-Value="form.EncounterDate" class="form-control" />
                </div>
                <div class="form-group" style="flex:0.5">
                    <label>Dauer (Min.)</label>
                    <InputNumber @bind-Value="form.DurationMinutes" class="form-control" />
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>ICD-10-GM Diagnosen</legend>

            @if (dauerdiagnosen.Count > 0)
            {
                <div class="dauer-section">
                    <span class="dauer-label">Dauerdiagnosen (geerbt):</span>
                    <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.3rem;">
                        @foreach (var d in dauerdiagnosen)
                        {
                            var isChecked = selectedDauerdiagnosen.Contains(d.Id);
                            <label class="dauer-chip @(isChecked ? "" : "dauer-unchecked")" title="@d.Icd10Description">
                                <input type="checkbox" checked="@isChecked"
                                       @onchange="e => ToggleDauerdiagnose(d.Id, (bool)(e.Value ?? false))" />
                                <span class="certainty-mini certainty-@d.Certainty.ToString().ToLower()">@d.Certainty</span>
                                <strong>@d.Icd10Code</strong>
                                @d.Icd10Description
                            </label>
                        }
                    </div>
                </div>
            }

            <div class="icd-search" style="position:relative;">
                <div style="display:flex;gap:0;">
                    <input type="text"
                           @bind="icdSearchTerm"
                           @bind:event="oninput"
                           @bind:after="SearchIcd"
                           @onfocus="OnIcdFocus"
                           placeholder="ICD-10 Code oder Beschreibung suchen..."
                           class="form-control"
                           style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                    <button type="button"
                            class="btn btn-secondary"
                            style="border-top-left-radius:0;border-bottom-left-radius:0;padding:0 0.75rem;min-width:2.5rem;font-size:0.8rem;"
                            @onclick="ToggleIcdDropdown">
                        ▼
                    </button>
                </div>
                @if (showIcdDropdown && icdResults.Count > 0)
                {
                    <div class="search-dropdown" style="max-height:250px;overflow-y:auto;">
                        @foreach (var entry in icdResults)
                        {
                            <div class="search-item" @onclick="() => AddIcd(entry)">
                                <span class="icd-code">@entry.Code</span>
                                <span class="icd-desc">@entry.Description</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.5rem;">
                @foreach (var icd in form.Icd10Codes)
                {
                    var desc = icdDescriptions.GetValueOrDefault(icd, "");
                    <span style="display:inline-flex;align-items:center;gap:0.5rem;background:#e0f2fe;border:1px solid #7dd3fc;border-radius:6px;padding:0.35rem 0.6rem;font-size:0.85rem;">
                        <strong>@icd</strong> @desc
                        <button type="button" @onclick="() => RemoveIcd(icd)"
                                style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:#64748b;padding:0 0.2rem;line-height:1;">&times;</button>
                    </span>
                }
                @if (form.Icd10Codes.Count == 0)
                {
                    <span class="no-codes">Keine Diagnosen hinzugefügt.</span>
                }
            </div>
        </fieldset>

        <fieldset>
            <legend>Strukturierte Befunde</legend>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                @if (isEdit)
                {
                    <a href="/dokumentation/psychopath-befund/@Id"
                       class="btn btn-sm @(compositeBefund?.PsychopathFindingId.HasValue == true ? "btn-primary" : "btn-secondary")">
                        Psychopath. Befund (AMDP) @(compositeBefund?.PsychopathFindingId.HasValue == true ? " ✓" : "")
                    </a>
                    <a href="/dokumentation/neurologischer-befund/@Id"
                       class="btn btn-sm @(compositeBefund?.NeuroExamId.HasValue == true ? "btn-primary" : "btn-secondary")">
                        Neurologischer Befund @(compositeBefund?.NeuroExamId.HasValue == true ? " ✓" : "")
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => SaveAndNavigate("psychopath-befund")'>Psychopath. Befund (AMDP)</button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => SaveAndNavigate("neurologischer-befund")'>Neurologischer Befund</button>
                }
                <a href="/patienten/@PatientId/suizidalitaet" class="btn btn-sm btn-secondary">Suizidalität</a>
            </div>
        </fieldset>

        <fieldset>
            <legend>Krankheitsspezifische Module</legend>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                <a href="/patienten/@PatientId/anfallskalender" class="btn btn-sm btn-secondary">Anfallskalender</a>
                <a href="/patienten/@PatientId/kopfschmerz-tagebuch" class="btn btn-sm btn-secondary">Kopfschmerz-Tagebuch</a>
                <a href="/patienten/@PatientId/ms-dokumentation" class="btn btn-sm btn-secondary">MS-Dokumentation</a>
                <a href="/patienten/@PatientId/parkinson-dokumentation" class="btn btn-sm btn-secondary">Parkinson</a>
            </div>
        </fieldset>

        <fieldset>
            <legend>Dokumentation (ABDTP)</legend>

            @if (hasLegacyNotes)
            {
                <div class="legacy-notes-banner">
                    <span>Diese Konsultation enthält unstrukturierte Notizen.</span>
                    <button type="button" class="btn btn-sm btn-accent" @onclick="MigrateNotes" disabled="@migrating">
                        @(migrating ? "Migriere..." : "Zu Sektionen migrieren")
                    </button>
                </div>
                <div class="form-group">
                    <label>Notizen (alt)</label>
                    <InputTextArea @bind-Value="form.Notes" class="form-control notes-area" rows="6" />
                </div>
            }

            <div class="template-bar">
                <span class="template-label">Vorlage:</span>
                <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplySectionTemplate("psych")'>Psychiatrisch</button>
                <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplySectionTemplate("neuro")'>Neurologisch</button>
                <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplySectionTemplate("kurz")'>Kurzkonsultation</button>
            </div>

            <div class="abdtp-sections">
                @foreach (var sectionType in abdtpOrder)
                {
                    <div class="abdtp-section">
                        <label class="abdtp-label">
                            <span class="abdtp-key">@GetSectionKey(sectionType)</span>
                            @GetSectionLabel(sectionType)
                        </label>

                        @if (sectionType == EncounterSectionType.Befund && isEdit)
                        {
                            @* Integrated Befund: structured findings + free-text *@
                            <div class="befund-composite">
                                @if (!string.IsNullOrEmpty(compositeBefund?.PsychopathNarrative))
                                {
                                    <div class="structured-finding-block">
                                        <div class="structured-finding-header">
                                            <span class="finding-title">Psychopathologischer Befund (AMDP)</span>
                                            <a href="/dokumentation/psychopath-befund/@Id"
                                               class="btn btn-sm btn-outline-secondary">Bearbeiten</a>
                                        </div>
                                        <div class="structured-finding-text">
                                            @compositeBefund.PsychopathNarrative
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <a href="/dokumentation/psychopath-befund/@Id"
                                       class="btn btn-sm btn-outline-primary structured-finding-add">
                                        + Psychopathologischen Befund erheben
                                    </a>
                                }

                                @if (!string.IsNullOrEmpty(compositeBefund?.NeuroNarrative))
                                {
                                    <div class="structured-finding-block">
                                        <div class="structured-finding-header">
                                            <span class="finding-title">Neurologischer Befund</span>
                                            <a href="/dokumentation/neurologischer-befund/@Id"
                                               class="btn btn-sm btn-outline-secondary">Bearbeiten</a>
                                        </div>
                                        <div class="structured-finding-text">
                                            @compositeBefund.NeuroNarrative
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <a href="/dokumentation/neurologischer-befund/@Id"
                                       class="btn btn-sm btn-outline-primary structured-finding-add">
                                        + Neurologischen Befund erheben
                                    </a>
                                }

                                <label class="form-label befund-freitext-label">Ergaenzender Befund</label>
                                <TextModuleAutocomplete
                                    Value="@sectionContents[EncounterSectionType.Befund]"
                                    ValueChanged="@(v => sectionContents[EncounterSectionType.Befund] = v)"
                                    Rows="4"
                                    Placeholder="Weitere klinische Beobachtungen..."
                                    CssClass="form-control abdtp-textarea"
                                    PatientId="@PatientId"
                                    EncounterId="@Id"
                                    DoctorId="@(Guid.TryParse(form.DoctorId, out var docGuid2) ? docGuid2 : null)"
                                    SectionFilter="EncounterSectionType.Befund" />
                            </div>
                        }
                        else
                        {
                            @* Standard textarea for A, D, T, P, S and Befund in create mode *@
                            <TextModuleAutocomplete
                                Value="@sectionContents[sectionType]"
                                ValueChanged="@(v => sectionContents[sectionType] = v)"
                                Rows="@GetSectionRows(sectionType)"
                                Placeholder="@GetSectionPlaceholder(sectionType)"
                                CssClass="form-control abdtp-textarea"
                                PatientId="@PatientId"
                                EncounterId="@Id"
                                DoctorId="@(Guid.TryParse(form.DoctorId, out var docGuid) ? docGuid : null)"
                                SectionFilter="@sectionType" />
                        }
                    </div>
                }
            </div>
        </fieldset>

        <fieldset>
            <legend>Status</legend>
            <InputSelect @bind-Value="form.Status" class="form-control" style="max-width:200px">
                <option value="Open">Offen</option>
                <option value="InProgress">In Bearbeitung</option>
                <option value="Completed">Abgeschlossen</option>
            </InputSelect>
        </fieldset>

        @if (isEdit)
        {
            <fieldset>
                <legend>⚡ Aktionskette</legend>
                <div class="chain-search" style="position:relative;">
                    <input type="text"
                           @bind="chainSearchTerm"
                           @bind:event="oninput"
                           @bind:after="SearchChains"
                           @onkeydown="HandleChainKeydown"
                           placeholder="# eingeben für Aktionsketten... (z.B. #dep)"
                           class="form-control" />
                    @if (showChainDropdown && chainResults.Count > 0)
                    {
                        <div class="search-dropdown">
                            @foreach (var chain in chainResults)
                            {
                                <div class="search-item" @onclick="() => ExecuteChain(chain)">
                                    <code class="icd-code">#@chain.Shortcut</code>
                                    <span class="icd-desc"><strong>@chain.Title</strong> — @chain.StepCount Schritte</span>
                                    <span class="gop-type">@chain.Category</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (chainResult is not null)
                {
                    <div class="chain-result @(chainResult.Success ? "chain-success" : "chain-warning")">
                        <strong>@chainResult.StepsExecuted/@(chainResult.StepsExecuted + chainResult.StepsFailed) Schritte ausgeführt.</strong>
                        @foreach (var r in chainResult.Results.Where(r => r.Success))
                        {
                            <div class="chain-detail">✓ @r.Detail</div>
                        }
                        @foreach (var w in chainResult.Warnings)
                        {
                            <div class="chain-warn-item">⚠ @w</div>
                        }
                    </div>
                }
                @if (executingChain)
                {
                    <p style="color:var(--color-text-secondary);font-size:0.85rem;">Aktionskette wird ausgeführt...</p>
                }
            </fieldset>
        }

        <fieldset>
            <legend>Abrechnung</legend>
            @if (!isEdit)
            {
                <p class="no-codes">Bitte speichern Sie zuerst, um Abrechnungspositionen hinzuzufügen.</p>
            }
            else
            {

                <div class="gop-search" style="position:relative;">
                    <div style="display:flex;gap:0;">
                        <input type="text"
                               @bind="gopSearchTerm"
                               @bind:event="oninput"
                               @bind:after="SearchGop"
                               @onfocus="OnGopFocus"
                               placeholder="GOP-Ziffer oder Beschreibung suchen..."
                               class="form-control"
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <button type="button"
                                class="btn btn-secondary"
                                style="border-top-left-radius:0;border-bottom-left-radius:0;padding:0 0.75rem;min-width:2.5rem;font-size:0.8rem;"
                                @onclick="ToggleGopDropdown">
                            ▼
                        </button>
                    </div>
                    @if (showGopDropdown && gopResults.Count > 0)
                    {
                        <div class="search-dropdown" style="max-height:250px;overflow-y:auto;">
                            @foreach (var entry in gopResults)
                            {
                                <div class="search-item" @onclick="() => AddGop(entry)">
                                    <span class="icd-code">@entry.Code</span>
                                    <span class="icd-desc">@entry.Description</span>
                                    <span class="gop-type">@entry.Type</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (billingItems.Count > 0)
                {
                    <table class="billing-table">
                        <thead>
                            <tr>
                                <th>GOP</th>
                                <th>Beschreibung</th>
                                <th>Typ</th>
                                <th class="text-right">Betrag</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in billingItems)
                            {
                                <tr>
                                    <td class="gop-code">@item.GopCode</td>
                                    <td>@(item.GopDescription ?? "—")</td>
                                    <td><span class="type-badge type-@item.BillingType.ToString().ToLower()">@item.BillingTypeDisplay</span></td>
                                    <td class="text-right">@item.Amount.ToString("N2") €</td>
                                    <td>
                                        @if (!item.KvdtExported)
                                        {
                                            <button type="button" class="btn-link danger" @onclick="() => RemoveGop(item.Id)">×</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="text-right"><strong>Gesamt:</strong></td>
                                <td class="text-right"><strong>@billingItems.Sum(i => i.Amount).ToString("N2") €</strong></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <p class="no-codes">Keine Abrechnungspositionen hinzugefügt.</p>
                }
            }
        </fieldset>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary" disabled="@saving">
                @(saving ? "Speichern..." : "Speichern")
            </button>
            <a href="@backUrl" class="btn btn-secondary">Abbrechen</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid? PatientId { get; set; }
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery] public Guid? DoctorIdQuery { get; set; }
    [SupplyParameterFromQuery] public int? DurationQuery { get; set; }
    [SupplyParameterFromQuery] public Guid? AppointmentIdQuery { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private EncounterFormModel form = new();
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private IReadOnlyList<Icd10CodeDto> icdResults = [];
    private Dictionary<string, string> icdDescriptions = new();
    private IReadOnlyList<MediPrax.Application.Data.GopCatalog.GopEntry> gopResults = [];
    private List<BillingItemDto> billingItems = [];
    private string icdSearchTerm = string.Empty;
    private bool showIcdDropdown;
    private string gopSearchTerm = string.Empty;
    private bool showGopDropdown;
    // Action chains
    private string chainSearchTerm = string.Empty;
    private bool showChainDropdown;
    private IReadOnlyList<ActionChainDto> chainResults = [];
    private ActionChainResult? chainResult;
    private bool executingChain;
    private string? patientName;
    private CompositeBefundDto? compositeBefund;
    private string backUrl = "/patienten";
    private bool isEdit => Id.HasValue;
    private bool loading = true;
    private bool saving;
    private bool migrating;
    private bool hasLegacyNotes;
    private string? errorMessage;

    // ABDTP section fields
    private static readonly EncounterSectionType[] abdtpOrder =
    [
        EncounterSectionType.Anamnese,
        EncounterSectionType.Befund,
        EncounterSectionType.Diagnose,
        EncounterSectionType.Therapie,
        EncounterSectionType.Procedere,
        EncounterSectionType.Sonstiges
    ];
    private Dictionary<EncounterSectionType, string> sectionContents = abdtpOrder.ToDictionary(t => t, _ => string.Empty);

    // M44: Inherited Dauerdiagnosen
    private IReadOnlyList<PatientDiagnosisDto> dauerdiagnosen = [];
    private HashSet<Guid> selectedDauerdiagnosen = new();

    protected override async Task OnInitializedAsync()
    {
        doctors = await UserService.GetDoctorsAsync();

        if (isEdit)
        {
            var encounter = await EncounterService.GetByIdAsync(Id!.Value);
            if (encounter is null) { Navigation.NavigateTo("/patienten"); return; }

            PatientId = encounter.PatientId;
            patientName = encounter.PatientName;
            backUrl = $"/patienten/{PatientId}";
            billingItems = (await BillingService.GetByEncounterAsync(Id!.Value)).ToList();
            form = new EncounterFormModel
            {
                DoctorId = encounter.DoctorId.ToString(),
                EncounterDate = encounter.EncounterDate,
                DurationMinutes = encounter.DurationMinutes,
                Notes = encounter.Notes,
                Icd10Codes = encounter.Icd10Codes.Select(c => c.Code).ToList(),
                Status = encounter.Status.ToString()
            };
            // Load descriptions for existing codes
            foreach (var c in form.Icd10Codes)
            {
                var desc = await Icd10Service.GetDescriptionAsync(c);
                if (desc is not null) icdDescriptions[c] = desc;
            }

            // Load ABDTP sections
            var sections = await SectionService.GetByEncounterAsync(Id!.Value);
            if (sections.Count > 0)
            {
                foreach (var s in sections)
                    sectionContents[s.SectionType] = s.Content;
                hasLegacyNotes = false;
            }
            else
            {
                hasLegacyNotes = !string.IsNullOrWhiteSpace(encounter.Notes);
            }

            // Load composite Befund (AMDP + Neuro + free-text, composed at read-time)
            compositeBefund = await CompositeBefundService.GetAsync(Id!.Value);
        }
        else if (PatientId.HasValue)
        {
            var patient = await PatientService.GetByIdAsync(PatientId.Value);
            patientName = patient?.FullName;
            backUrl = $"/patienten/{PatientId}";
            form.EncounterDate = DateOnly.FromDateTime(DateTime.Today);
            if (DoctorIdQuery.HasValue)
                form.DoctorId = DoctorIdQuery.Value.ToString();
            if (DurationQuery.HasValue)
                form.DurationMinutes = DurationQuery.Value;

            // Load Dauerdiagnosen for inheritance
            dauerdiagnosen = await DiagnosisService.GetDauerdiagnosenAsync(PatientId.Value);
            selectedDauerdiagnosen = new HashSet<Guid>(dauerdiagnosen.Select(d => d.Id));

            // Pre-select logged-in doctor if no doctor set yet
            if (string.IsNullOrEmpty(form.DoctorId) && AuthState is not null)
            {
                var auth = await AuthState;
                var role = auth.User.FindFirst(ClaimTypes.Role)?.Value;
                if (role == "Arzt")
                {
                    var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                    if (userId is not null) form.DoctorId = userId;
                }
            }
        }

        loading = false;
    }

    private async Task SearchIcd()
    {
        if (string.IsNullOrWhiteSpace(icdSearchTerm))
        {
            showIcdDropdown = false;
            icdResults = [];
        }
        else
        {
            icdResults = await Icd10Service.SearchAsync(icdSearchTerm);
            showIcdDropdown = icdResults.Count > 0;
        }
    }

    private async Task OnIcdFocus()
    {
        if (!showIcdDropdown)
            await ToggleIcdDropdown();
    }

    private async Task ToggleIcdDropdown()
    {
        if (showIcdDropdown) { showIcdDropdown = false; return; }
        if (string.IsNullOrWhiteSpace(icdSearchTerm))
        {
            icdResults = await Icd10Service.GetAllAsync();
        }
        else
        {
            icdResults = await Icd10Service.SearchAsync(icdSearchTerm);
        }
        showIcdDropdown = icdResults.Count > 0;
    }

    private void AddIcd(Icd10CodeDto entry)
    {
        if (!form.Icd10Codes.Contains(entry.Code))
        {
            form.Icd10Codes.Add(entry.Code);
            icdDescriptions[entry.Code] = entry.Description;
        }
        icdSearchTerm = string.Empty;
        icdResults = [];
        showIcdDropdown = false;
    }

    private void RemoveIcd(string code)
    {
        form.Icd10Codes.Remove(code);
        icdDescriptions.Remove(code);
    }

    // --- Action Chain methods ---

    private async Task SearchChains()
    {
        chainResult = null;
        if (string.IsNullOrWhiteSpace(chainSearchTerm) || !chainSearchTerm.StartsWith('#'))
        {
            showChainDropdown = false;
            chainResults = [];
            return;
        }

        var term = chainSearchTerm.TrimStart('#');
        if (term.Length < 1) { showChainDropdown = false; return; }

        chainResults = await ActionChainService.SearchAsync(term);
        showChainDropdown = chainResults.Count > 0;
    }

    private async Task HandleChainKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && chainResults.Count == 1)
        {
            await ExecuteChain(chainResults[0]);
        }
        else if (e.Key == "Escape")
        {
            showChainDropdown = false;
            chainSearchTerm = "";
        }
    }

    private async Task ExecuteChain(ActionChainDto chain)
    {
        showChainDropdown = false;
        chainSearchTerm = "";
        executingChain = true;
        chainResult = null;

        try
        {
            chainResult = await ActionChainExecutor.ExecuteAsync(chain.Id, Id!.Value);

            // Refresh billing items, sections, and diagnoses
            billingItems = (await BillingService.GetByEncounterAsync(Id!.Value)).ToList();

            var sections = await SectionService.GetByEncounterAsync(Id!.Value);
            foreach (var s in sections)
                sectionContents[s.SectionType] = s.Content;

            dauerdiagnosen = await DiagnosisService.GetDauerdiagnosenAsync(PatientId!.Value);

            // Refresh encounter to get updated duration
            var enc = await EncounterService.GetByIdAsync(Id!.Value);
            if (enc is not null)
                form.DurationMinutes = enc.DurationMinutes;
        }
        catch (Exception ex)
        {
            chainResult = new ActionChainResult(false, 0, 0, [], [ex.Message]);
        }
        finally
        {
            executingChain = false;
        }
    }

    private void SearchGop()
    {
        if (string.IsNullOrWhiteSpace(gopSearchTerm))
        {
            showGopDropdown = false;
            gopResults = [];
        }
        else
        {
            gopResults = MediPrax.Application.Data.GopCatalog.Search(gopSearchTerm);
            showGopDropdown = gopResults.Count > 0;
        }
    }

    private void OnGopFocus()
    {
        if (!showGopDropdown)
            ToggleGopDropdown();
    }

    private void ToggleGopDropdown()
    {
        if (showGopDropdown) { showGopDropdown = false; return; }
        if (string.IsNullOrWhiteSpace(gopSearchTerm))
        {
            gopResults = MediPrax.Application.Data.GopCatalog.GetAll();
        }
        else
        {
            gopResults = MediPrax.Application.Data.GopCatalog.Search(gopSearchTerm);
        }
        showGopDropdown = gopResults.Count > 0;
    }

    private async Task AddGop(MediPrax.Application.Data.GopCatalog.GopEntry entry)
    {
        var item = await BillingService.AddAsync(new CreateBillingItemDto
        {
            EncounterId = Id!.Value,
            PatientId = PatientId!.Value,
            GopCode = entry.Code,
            Quantity = 1,
            BillingType = entry.Type
        });
        billingItems.Add(item);
        gopSearchTerm = string.Empty;
        gopResults = [];
        showGopDropdown = false;
    }

    private async Task RemoveGop(Guid billingItemId)
    {
        await BillingService.DeleteAsync(billingItemId);
        billingItems.RemoveAll(b => b.Id == billingItemId);
    }

    private void ApplySectionTemplate(string template)
    {
        switch (template)
        {
            case "psych":
                sectionContents[EncounterSectionType.Befund] =
                    "Bewusstsein: klar / getrübt\nOrientierung: zeitlich / örtlich / situativ / zur Person — orientiert / desorientiert\nAntrieb: normal / gesteigert / vermindert\nStimmung: euthym / depressiv / gehoben / gereizt\nAffekt: moduliert / eingeengt / flach / inadäquat\nFormales Denken: geordnet / verlangsamt / beschleunigt / umständlich\nInhaltliches Denken: unauffällig / Wahn / Zwangsgedanken\nWahrnehmung: unauffällig / Halluzinationen (akustisch / optisch)\nIch-Störungen: keine / Gedankeneingebung / -entzug / -ausbreitung\nSuizidalität: keine / Gedanken / Absichten / Pläne";
                break;
            case "neuro":
                sectionContents[EncounterSectionType.Befund] =
                    "Hirnnerven: unauffällig / Auffälligkeiten:\nMotorik: Tonus normal / erhöht / schlaff; Kraft seitengleich / Paresen:\nReflexe: seitengleich / Seitendifferenz; Pathologische Reflexe:\nSensibilität: unauffällig / Hypästhesie / Parästhesien:\nKoordination: Finger-Nase-Versuch / Knie-Hacke-Versuch — unauffällig / Dysmetrie\nGang: sicher / unsicher / Ataxie / Spastik\nSprache: unauffällig / Dysarthrie / Aphasie";
                break;
            case "kurz":
                sectionContents[EncounterSectionType.Anamnese] = "Aktueller Zustand:";
                sectionContents[EncounterSectionType.Therapie] = "Medikation: unverändert / Anpassung:";
                sectionContents[EncounterSectionType.Procedere] = $"Nächster Termin:";
                break;
        }
    }

    private async Task MigrateNotes()
    {
        if (!isEdit || !hasLegacyNotes) return;
        migrating = true;

        try
        {
            Guid.TryParse(form.DoctorId, out var authorId);
            await SectionService.MigrateNotesToSectionsAsync(Id!.Value, authorId != Guid.Empty ? authorId : null);

            var sections = await SectionService.GetByEncounterAsync(Id!.Value);
            sectionContents = abdtpOrder.ToDictionary(t => t, _ => string.Empty);
            foreach (var s in sections)
                sectionContents[s.SectionType] = s.Content;

            hasLegacyNotes = false;
            form.Notes = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            migrating = false;
        }
    }

    private List<CreateEncounterSectionDto> BuildSectionDtos(Guid authorId)
    {
        return sectionContents
            .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
            .Select(kv => new CreateEncounterSectionDto
            {
                SectionType = kv.Key,
                Content = kv.Value,
                AuthorId = authorId
            })
            .ToList();
    }

