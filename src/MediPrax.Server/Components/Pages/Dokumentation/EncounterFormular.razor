    private void ToggleDauerdiagnose(Guid id, bool isChecked)
    {
        if (isChecked) selectedDauerdiagnosen.Add(id);
        else selectedDauerdiagnosen.Remove(id);
    }

    private List<string> BuildAllIcd10Codes()
    {
        var codes = new List<string>();
        // Add selected Dauerdiagnosen codes
        foreach (var d in dauerdiagnosen.Where(d => selectedDauerdiagnosen.Contains(d.Id)))
            if (!codes.Contains(d.Icd10Code)) codes.Add(d.Icd10Code);
        // Add manually added codes
        foreach (var c in form.Icd10Codes)
            if (!codes.Contains(c)) codes.Add(c);
        return codes;
    }

