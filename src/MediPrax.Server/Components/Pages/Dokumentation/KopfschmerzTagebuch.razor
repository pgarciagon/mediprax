@page "/patienten/{PatientId:guid}/kopfschmerz-tagebuch"
@attribute [Authorize(Policy = "Klinisch")]
@inject IHeadacheDiaryService HeadacheDiaryService
@inject IPatientService PatientService
@rendermode InteractiveServer

<PageTitle>Kopfschmerz-Tagebuch — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <SuicidalityAlert PatientId="PatientId" />

    <div class="page-header">
        <div>
            <a href="/patienten/@PatientId" class="back-link">&larr; @patient.FullName</a>
            <h1>Kopfschmerz-Tagebuch</h1>
        </div>
        <button class="btn btn-primary btn-sm" @onclick="() => showForm = !showForm">+ Neuer Eintrag</button>
    </div>

    @if (showForm)
    {
        <div class="card form-card">
            <h3>Kopfschmerz dokumentieren</h3>
            <div class="form-row">
                <div class="form-group">
                    <label>Datum *</label>
                    <input class="form-control" @bind="formDateStr" placeholder="2026-04-09" />
                </div>
                <div class="form-group">
                    <label>Typ *</label>
                    <select class="form-control" @bind="form.Type">
                        <option value="Migräne">Migräne</option>
                        <option value="Spannungskopfschmerz">Spannungskopfschmerz</option>
                        <option value="Cluster">Cluster</option>
                        <option value="Andere">Andere</option>
                    </select>
                </div>
                <div class="form-group" style="flex:0.4">
                    <label>Intensität (0–10) *</label>
                    <input type="number" class="form-control" @bind="form.Intensity" min="0" max="10" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:0.5">
                    <label>Dauer (Std.)</label>
                    <input type="number" class="form-control" @bind="form.DurationHours" step="0.5" />
                </div>
                <div class="form-group">
                    <label>Lokalisation</label>
                    <select class="form-control" @bind="form.Location">
                        <option value="">—</option>
                        <option value="Einseitig rechts">Einseitig rechts</option>
                        <option value="Einseitig links">Einseitig links</option>
                        <option value="Beidseits">Beidseits</option>
                        <option value="Frontal">Frontal</option>
                        <option value="Okzipital">Okzipital</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex:0.3"><label><input type="checkbox" @bind="form.AuraPresent" /> Aura</label></div>
                <div class="form-group" style="flex:0.3"><label><input type="checkbox" @bind="form.Nausea" /> Übelkeit</label></div>
                <div class="form-group" style="flex:0.4"><label><input type="checkbox" @bind="form.Photophobia" /> Lichtempf.</label></div>
                <div class="form-group" style="flex:0.4"><label><input type="checkbox" @bind="form.Phonophobia" /> Geräuschempf.</label></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label>Medikament</label><input class="form-control" @bind="form.MedicationTaken" /></div>
                <div class="form-group" style="flex:0.4">
                    <label>Wirksam?</label>
                    <select class="form-control" @bind="medicationEffectiveStr">
                        <option value="">—</option><option value="true">Ja</option><option value="false">Nein</option>
                    </select>
                </div>
            </div>
            <div style="display:flex;gap:.5rem;margin-top:.5rem">
                <button class="btn btn-primary btn-sm" @onclick="Save">Speichern</button>
                <button class="btn btn-secondary btn-sm" @onclick="() => showForm = false">Abbrechen</button>
            </div>
        </div>
    }

    @if (entries is not null && entries.Count > 0)
    {
        <div class="summary-cards" style="display:flex;gap:1rem;margin:1rem 0;">
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.Count</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Einträge gesamt</div>
            </div>
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.Count(e => e.Date >= DateOnly.FromDateTime(DateTime.Today.AddDays(-30)))</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Letzte 30 Tage</div>
            </div>
            <div class="detail-card" style="flex:1;padding:1rem;">
                <div style="font-size:1.5rem;font-weight:700;color:var(--color-primary)">@entries.Average(e => e.Intensity).ToString("F1")</div>
                <div style="font-size:0.75rem;color:var(--color-text-secondary)">Ø Intensität</div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr><th>Datum</th><th>Typ</th><th>Intensität</th><th>Dauer</th><th>Aura</th><th>Begleitsympt.</th><th>Medikament</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var entry in entries)
                {
                    var sx = new List<string>();
                    if (entry.Nausea) sx.Add("Übelk.");
                    if (entry.Photophobia) sx.Add("Licht");
                    if (entry.Phonophobia) sx.Add("Geräusch");
                    <tr>
                        <td>@entry.Date.ToString("dd.MM.yyyy")</td>
                        <td>@entry.Type</td>
                        <td>@entry.IntensityDisplay</td>
                        <td>@(entry.DurationHours.HasValue ? $"{entry.DurationHours:F1}h" : "—")</td>
                        <td>@(entry.AuraPresent ? "Ja" : "—")</td>
                        <td>@(sx.Count > 0 ? string.Join(", ", sx) : "—")</td>
                        <td>@(entry.MedicationTaken ?? "—") @(entry.MedicationEffective == true ? "✓" : entry.MedicationEffective == false ? "✗" : "")</td>
                        <td><button class="btn btn-sm btn-link danger" @onclick="() => Delete(entry.Id)">Löschen</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (entries is not null)
    {
        <div class="empty-encounters">Noch keine Kopfschmerzen dokumentiert.</div>
    }
}

@code {
    [Parameter] public Guid PatientId { get; set; }

    private PatientDto? patient;
    private IReadOnlyList<HeadacheDiaryDto>? entries;
    private CreateHeadacheDiaryDto form = new() { Type = "Migräne" };
    private string formDateStr = DateTime.Today.ToString("yyyy-MM-dd");
    private string medicationEffectiveStr = string.Empty;
    private bool showForm;

    protected override async Task OnInitializedAsync()
    {
        patient = await PatientService.GetByIdAsync(PatientId);
        form.PatientId = PatientId;
        await LoadEntries();
    }

    private async Task LoadEntries() => entries = await HeadacheDiaryService.GetByPatientAsync(PatientId);

    private async Task Save()
    {
        form.PatientId = PatientId;
        if (DateOnly.TryParse(formDateStr, out var date)) form.Date = date;
        form.MedicationEffective = bool.TryParse(medicationEffectiveStr, out var v) ? v : null;
        await HeadacheDiaryService.CreateAsync(form);
        form = new() { PatientId = PatientId, Type = "Migräne" };
        formDateStr = DateTime.Today.ToString("yyyy-MM-dd");
        medicationEffectiveStr = string.Empty;
        showForm = false;
        await LoadEntries();
    }

    private async Task Delete(Guid id) { await HeadacheDiaryService.DeleteAsync(id); await LoadEntries(); }
}
