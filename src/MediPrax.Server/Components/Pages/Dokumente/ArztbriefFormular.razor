@page "/patienten/{PatientId:guid}/arztbrief/neu"
@page "/arztbrief/{EditId:guid}"
@attribute [Authorize(Policy = "Arzt")]
@inject IArztbriefService ArztbriefService
@inject IPatientService PatientService
@inject IEncounterService EncounterService
@inject IMedicationService MedicationService
@inject IUserService UserService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Neuer Arztbrief — @(patient?.FullName ?? "Laden...")</PageTitle>

@if (patient is null)
{
    <p>Laden...</p>
}
else
{
    <div class="page-header">
        <div>
            <a href="/patienten/@PatientId" class="patient-context">&larr; @patient.FullName</a>
            <h1>Neuer Arztbrief</h1>
        </div>
    </div>

    <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="arztbriefForm">
        <fieldset>
            <legend>Arzt & Konsultation</legend>
            <div class="form-row">
                <div class="form-group">
                    <label>Arzt *</label>
                    <InputSelect @bind-Value="form.DoctorId" class="form-control">
                        <option value="">— Arzt wählen —</option>
                        @foreach (var doc in doctors)
                        {
                            <option value="@doc.Id">@doc.FullName</option>
                        }
                    </InputSelect>
                </div>
                <div class="form-group">
                    <label>Konsultation (optional)</label>
                    <select class="form-control" @onchange="OnEncounterChanged">
                        <option value="">— Ohne Bezug —</option>
                        @foreach (var enc in encounters)
                        {
                            <option value="@enc.Id" selected="@(form.EncounterId == enc.Id.ToString())">@enc.EncounterDate.ToString("dd.MM.yyyy") — @string.Join(", ", enc.Icd10Codes)</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Empfänger</legend>
            <div class="form-row">
                <div class="form-group">
                    <label>Name / Praxis *</label>
                    <InputText @bind-Value="form.RecipientName" class="form-control" placeholder="Dr. med. ..." />
                </div>
                <div class="form-group">
                    <label>Adresse</label>
                    <InputText @bind-Value="form.RecipientAddress" class="form-control" placeholder="Straße, PLZ Ort" />
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Inhalt</legend>
            <div class="form-row">
                <div class="form-group">
                    <label>Betreff</label>
                    <InputText @bind-Value="form.Subject" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label>Diagnosen</label>
                <div class="icd-search">
                    <input type="text"
                           @bind="icdSearchTerm"
                           @bind:event="oninput"
                           @bind:after="SearchIcd"
                           placeholder="ICD-10 suchen..."
                           class="form-control" />
                    @if (icdResults.Count > 0)
                    {
                        <div class="search-dropdown">
                            @foreach (var entry in icdResults)
                            {
                                <div class="search-item" @onclick="() => AddIcd(entry)">
                                    <span class="icd-code">@entry.Code</span>
                                    <span class="icd-desc">@entry.Description</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="icd-tags">
                    @foreach (var icd in form.Diagnoses)
                    {
                        var desc = MediPrax.Application.Data.Icd10Catalog.GetDescription(icd);
                        <span class="icd-tag">
                            <strong>@icd</strong> @desc
                            <button type="button" class="tag-remove" @onclick="() => form.Diagnoses.Remove(icd)">&times;</button>
                        </span>
                    }
                </div>
            </div>

            <div class="form-group" style="margin-top: 0.8rem">
                <label>Brieftext *</label>
                <div class="template-bar">
                    <span class="template-label">Vorlage:</span>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplyTemplate("ueberweisung")'>Überweisung</button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplyTemplate("befund")'>Befundbericht</button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplyTemplate("verlauf")'>Verlaufsbericht</button>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick='() => ApplyTemplate("entlassung")'>Entlassungsbericht</button>
                </div>
                @if (selectedEncounter is not null)
                {
                    <div style="font-size:0.75rem;color:var(--color-text-secondary);margin:0.3rem 0;">
                        Vorlage wird mit Daten der Konsultation vom @selectedEncounter.EncounterDate.ToString("dd.MM.yyyy") befüllt.
                    </div>
                }
                <InputTextArea @bind-Value="form.Body" class="form-control notes-area" rows="18" />
            </div>
        </fieldset>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div style="color:var(--color-primary);font-size:0.85rem;margin-bottom:0.5rem;">@successMessage</div>
        }

        <div class="form-actions">
            @if (isEdit && arztbriefStatus == ArztbriefStatus.Versendet)
            {
                <span style="color:var(--color-text-secondary);font-size:0.85rem">Versendet — Keine Bearbeitung möglich</span>
            }
            else if (isEdit && arztbriefStatus == ArztbriefStatus.Freigegeben)
            {
                <button type="button" class="btn btn-secondary" @onclick="BackToEntwurf" disabled="@saving">
                    Bearbeiten (zurück zu Entwurf)
                </button>
                <button type="button" class="btn btn-primary" @onclick="MarkVersendet" disabled="@saving">
                    Als versendet markieren
                </button>
            }
            else
            {
                <button type="button" class="btn btn-secondary" @onclick="SaveDraft" disabled="@saving">
                    @(saving ? "Speichern..." : "Entwurf speichern")
                </button>
                <button type="button" class="btn btn-primary" @onclick="SaveAndGeneratePdf" disabled="@saving">
                    @(saving ? "PDF wird erzeugt..." : isEdit ? "PDF aktualisieren" : "PDF erzeugen")
                </button>
                @if (isEdit && hasPdf)
                {
                    <button type="button" class="btn btn-primary" @onclick="Freigeben" disabled="@saving">
                        Freigeben
                    </button>
                }
            }
            @if (isEdit && hasPdf)
            {
                <a href="/dokumente/@EditId/pdf" target="_blank" class="btn btn-secondary">PDF anzeigen</a>
            }
            <a href="/patienten/@PatientId" class="btn btn-secondary">Zurück</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public Guid PatientId { get; set; }
    [Parameter] public Guid? EditId { get; set; }

    private bool isEdit => EditId.HasValue;
    private PatientDto? patient;
    private ArztbriefFormModel form = new();
    private IReadOnlyList<DoctorListItemDto> doctors = [];
    private IReadOnlyList<EncounterListItemDto> encounters = [];
    private IReadOnlyList<MedicationDto> medications = [];
    private IReadOnlyList<MediPrax.Application.Data.Icd10Catalog.Icd10Entry> icdResults = [];
    private EncounterDto? selectedEncounter;
    private string icdSearchTerm = string.Empty;
    private bool saving;
    private bool hasPdf;
    private ArztbriefStatus arztbriefStatus;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (isEdit)
        {
            var detail = await ArztbriefService.GetByIdAsync(EditId!.Value);
            if (detail is null) { Navigation.NavigateTo("/patienten"); return; }

            PatientId = detail.PatientId;
            form.DoctorId = detail.DoctorId.ToString();
            form.EncounterId = detail.EncounterId?.ToString() ?? "";
            form.RecipientName = detail.RecipientName;
            form.RecipientAddress = detail.RecipientAddress;
            form.Subject = detail.Subject;
            form.Body = detail.Body;
            form.Diagnoses = detail.Diagnoses;
            hasPdf = detail.HasPdf;
            arztbriefStatus = detail.Status;
        }

        patient = await PatientService.GetByIdAsync(PatientId);
        if (patient is null) { Navigation.NavigateTo("/patienten"); return; }

        doctors = await UserService.GetDoctorsAsync();
        encounters = await EncounterService.GetByPatientAsync(PatientId);
        medications = await MedicationService.GetByPatientAsync(PatientId);

        if (!isEdit)
            form.Subject = $"Arztbrief — {patient.FullName}";
    }

    private async Task OnEncounterChanged(ChangeEventArgs e)
    {
        selectedEncounter = null;
        form.EncounterId = e.Value?.ToString() ?? "";

        if (Guid.TryParse(form.EncounterId, out var encId))
        {
            selectedEncounter = await EncounterService.GetByIdAsync(encId);
            if (selectedEncounter is not null)
            {
                // Transfer diagnoses
                form.Diagnoses = selectedEncounter.Icd10Codes.Select(c => c.Code).ToList();

                // Transfer doctor
                form.DoctorId = selectedEncounter.DoctorId.ToString();

                // Transfer subject with date
                form.Subject = $"Arztbrief — {patient!.FullName}, Konsultation {selectedEncounter.EncounterDate:dd.MM.yyyy}";

                // Auto-generate body text with encounter data
                var diagnosen = BuildDiagnosenBlock();
                var medikation = BuildMedikationBlock();
                var befund = selectedEncounter.Notes ?? "[Befund hier einfügen]";
                var anrede = GetAnrede();
                var pronomen = GetPronomen();
                var gebDatum = patient!.DateOfBirth.ToString("dd.MM.yyyy");

                form.Body = $"""
Sehr geehrte Kollegin, sehr geehrter Kollege,

wir berichten über {anrede} {patient.FullName}, geb. {gebDatum}, {pronomen} am {selectedEncounter.EncounterDate:dd.MM.yyyy} in unserer Praxis vorstellte.

Diagnosen:
{diagnosen}

Befund:
{befund}

Aktuelle Medikation:
{medikation}

Beurteilung und Procedere:
[Bitte ergänzen]

Für Rückfragen stehen wir jederzeit gerne zur Verfügung.

Mit freundlichen kollegialen Grüßen
""";
            }
        }
        else
        {
            form.Diagnoses.Clear();
            form.Body = string.Empty;
        }
    }

    private void SearchIcd()
    {
        icdResults = MediPrax.Application.Data.Icd10Catalog.Search(icdSearchTerm);
    }

    private void AddIcd(MediPrax.Application.Data.Icd10Catalog.Icd10Entry entry)
    {
        if (!form.Diagnoses.Contains(entry.Code))
            form.Diagnoses.Add(entry.Code);
        icdSearchTerm = string.Empty;
        icdResults = [];
    }

    // --- Smart template generation using patient + encounter + medication data ---

    private string BuildDiagnosenBlock()
    {
        if (form.Diagnoses.Count == 0) return "  (keine Diagnosen ausgewählt)";
        return string.Join("\n", form.Diagnoses.Select(icd =>
        {
            var desc = MediPrax.Application.Data.Icd10Catalog.GetDescription(icd);
            return $"  {icd} — {desc}";
        }));
    }

    private string BuildMedikationBlock()
    {
        if (medications.Count == 0) return "  Keine aktive Medikation.";
        return string.Join("\n", medications.Select(m =>
            $"  - {m.Name} {m.Staerke} {m.Dosierung}{(!string.IsNullOrEmpty(m.Hinweis) ? $" ({m.Hinweis})" : "")}"));
    }

    private string BuildBefundBlock()
    {
        if (selectedEncounter is null) return "[Befund hier einfügen]";
        return selectedEncounter.Notes ?? "[Befund hier einfügen]";
    }

    private string GetAnrede() => patient!.Gender switch
    {
        "M" => "unseren gemeinsamen Patienten",
        "W" => "unsere gemeinsame Patientin",
        _ => "unseren gemeinsamen Patienten/unsere gemeinsame Patientin"
    };

    private string GetPronomen() => patient!.Gender switch
    {
        "M" => "der sich",
        "W" => "die sich",
        _ => "der/die sich"
    };

    private string GetDatumBlock()
    {
        if (selectedEncounter is not null)
            return $"am {selectedEncounter.EncounterDate:dd.MM.yyyy}";
        return $"am {DateTime.Today:dd.MM.yyyy}";
    }

    private void ApplyTemplate(string template)
    {
        var diagnosen = BuildDiagnosenBlock();
        var medikation = BuildMedikationBlock();
        var befund = BuildBefundBlock();
        var anrede = GetAnrede();
        var pronomen = GetPronomen();
        var datum = GetDatumBlock();
        var gebDatum = patient!.DateOfBirth.ToString("dd.MM.yyyy");

        form.Body = template switch
        {
            "ueberweisung" => $"""
Sehr geehrte Kollegin, sehr geehrter Kollege,

wir überweisen Ihnen {anrede} {patient.FullName}, geb. {gebDatum}, mit der Bitte um Mitbeurteilung / Weiterbehandlung.

Diagnosen:
{diagnosen}

Anamnese:
{befund}

Aktuelle Medikation:
{medikation}

Fragestellung:
[Bitte ergänzen]

Für Rückfragen stehen wir jederzeit gerne zur Verfügung.

Mit freundlichen kollegialen Grüßen
""",
            "befund" => $"""
Sehr geehrte Kollegin, sehr geehrter Kollege,

wir berichten über {anrede} {patient.FullName}, geb. {gebDatum}, {pronomen} {datum} in unserer Praxis vorstellte.

Diagnosen:
{diagnosen}

Anamnese und Befund:
{befund}

Aktuelle Medikation:
{medikation}

Beurteilung und Procedere:
[Bitte ergänzen]

Für Rückfragen stehen wir jederzeit gerne zur Verfügung.

Mit freundlichen kollegialen Grüßen
""",
            "verlauf" => $"""
Sehr geehrte Kollegin, sehr geehrter Kollege,

wir berichten über den aktuellen Behandlungsverlauf {(patient.Gender == "W" ? "unserer Patientin" : "unseres Patienten")} {patient.FullName}, geb. {gebDatum}.

Diagnosen:
{diagnosen}

Aktueller Verlauf:
{befund}

Aktuelle Medikation:
{medikation}

Weiteres Procedere:
[Bitte ergänzen]

Für Rückfragen stehen wir jederzeit gerne zur Verfügung.

Mit freundlichen kollegialen Grüßen
""",
            "entlassung" => $"""
Sehr geehrte Kollegin, sehr geehrter Kollege,

wir berichten über {anrede} {patient.FullName}, geb. {gebDatum}, {pronomen} vom [Datum] bis {datum} in unserer Behandlung befand.

Diagnosen:
{diagnosen}

Aufnahmebefund:
[Bitte ergänzen]

Verlauf und Therapie:
{befund}

Entlassungsmedikation:
{medikation}

Empfehlungen:
[Bitte ergänzen]

Mit freundlichen kollegialen Grüßen
""",
            _ => form.Body
        };
    }

    private CreateArztbriefDto BuildDto()
    {
        Guid.TryParse(form.DoctorId, out var doctorId);
        Guid? encounterId = Guid.TryParse(form.EncounterId, out var eid) ? eid : null;
        return new CreateArztbriefDto
        {
            PatientId = PatientId,
            DoctorId = doctorId,
            EncounterId = encounterId,
            RecipientName = form.RecipientName,
            RecipientAddress = form.RecipientAddress,
            Subject = form.Subject,
            Body = form.Body,
            Diagnoses = form.Diagnoses
        };
    }

    private bool Validate()
    {
        errorMessage = null;
        successMessage = null;
        if (!Guid.TryParse(form.DoctorId, out _))
        { errorMessage = "Bitte wählen Sie einen Arzt."; return false; }
        if (string.IsNullOrWhiteSpace(form.RecipientName))
        { errorMessage = "Bitte geben Sie einen Empfänger an."; return false; }
        return true;
    }

    private async Task SaveDraft()
    {
        if (!Validate()) return;
        saving = true;
        try
        {
            if (isEdit)
            {
                await ArztbriefService.UpdateAsync(EditId!.Value, BuildDto());
                successMessage = "Entwurf gespeichert.";
            }
            else
            {
                var id = await ArztbriefService.SaveDraftAsync(BuildDto());
                Navigation.NavigateTo($"/arztbrief/{id}");
            }
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        saving = false;
    }

    private async Task SaveAndGeneratePdf()
    {
        if (!Validate()) return;
        saving = true;
        try
        {
            Guid briefId;
            if (isEdit)
            {
                await ArztbriefService.UpdateAsync(EditId!.Value, BuildDto());
                briefId = EditId!.Value;
            }
            else
            {
                briefId = await ArztbriefService.SaveDraftAsync(BuildDto());
            }
            await ArztbriefService.GeneratePdfAsync(briefId);
            hasPdf = true;
            if (!isEdit)
                Navigation.NavigateTo($"/arztbrief/{briefId}");
            else
                successMessage = "PDF erzeugt.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        saving = false;
    }

    private async Task Freigeben()
    {
        saving = true;
        try
        {
            if (!hasPdf)
                await ArztbriefService.GeneratePdfAsync(EditId!.Value);
            await ArztbriefService.UpdateStatusAsync(EditId!.Value, ArztbriefStatus.Freigegeben);
            arztbriefStatus = ArztbriefStatus.Freigegeben;
            hasPdf = true;
            successMessage = "Arztbrief freigegeben.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        saving = false;
    }

    private async Task MarkVersendet()
    {
        saving = true;
        try
        {
            await ArztbriefService.UpdateStatusAsync(EditId!.Value, ArztbriefStatus.Versendet);
            arztbriefStatus = ArztbriefStatus.Versendet;
            successMessage = "Arztbrief als versendet markiert.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        saving = false;
    }

    private async Task BackToEntwurf()
    {
        saving = true;
        try
        {
            await ArztbriefService.UpdateStatusAsync(EditId!.Value, ArztbriefStatus.Entwurf);
            arztbriefStatus = ArztbriefStatus.Entwurf;
            successMessage = "Zurück zu Entwurf — Bearbeitung möglich.";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        saving = false;
    }

    private async Task HandleSubmit() => await SaveDraft();

    private class ArztbriefFormModel
    {
        public string DoctorId { get; set; } = string.Empty;
        public string EncounterId { get; set; } = string.Empty;
        public string RecipientName { get; set; } = string.Empty;
        public string? RecipientAddress { get; set; }
        public string Subject { get; set; } = "Arztbrief";
        public string Body { get; set; } = string.Empty;
        public List<string> Diagnoses { get; set; } = [];
    }
}
