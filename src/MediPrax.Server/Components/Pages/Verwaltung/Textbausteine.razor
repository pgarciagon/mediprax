@page "/verwaltung/textbausteine"
@attribute [Authorize(Policy = "Klinisch")]
@inject ITextModuleService TextModuleService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveServer
@using System.Security.Claims
@using MediPrax.Core.Enums

<PageTitle>Textbausteine</PageTitle>

<div class="page-header">
    <h1>Textbausteine</h1>
    <a href="/verwaltung/textbausteine/neu" class="btn btn-primary">+ Neuer Textbaustein</a>
</div>

<div class="search-bar" style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
    <select class="form-control" style="width:220px" @bind="selectedCategory" @bind:after="LoadModules">
        <option value="">Alle Kategorien</option>
        @foreach (var cat in categories)
        {
            <option value="@cat">@cat</option>
        }
    </select>
    <select class="form-control" style="width:180px" @bind="sortBy" @bind:after="LoadModules">
        <option value="">Alphabetisch</option>
        <option value="usage">Meistverwendet</option>
        <option value="recent">Zuletzt verwendet</option>
    </select>
    <span style="flex:1"></span>
    <label class="btn-link" style="cursor:pointer;font-size:0.85rem">
        Importieren
        <InputFile OnChange="HandleImport" accept=".json" style="display:none" />
    </label>
    <button class="btn-link" style="font-size:0.85rem" @onclick="ExportModules">Exportieren</button>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="@(statusIsError ? "error-message" : "success-message")" style="margin-bottom:1rem">
        @statusMessage
    </div>
}

@if (modules is null)
{
    <p>Laden...</p>
}
else if (modules.Count == 0)
{
    <p class="empty-state">Keine Textbausteine gefunden.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Kuerzel</th>
                <th>Titel</th>
                <th>Kategorie</th>
                <th>Sektion</th>
                <th>Inhalt (Vorschau)</th>
                <th>Verwendungen</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in modules)
            {
                <tr>
                    <td><code>#@m.Shortcut</code></td>
                    <td><a href="/verwaltung/textbausteine/@m.Id/bearbeiten">@m.Title</a></td>
                    <td>@m.Category</td>
                    <td>@m.TargetSectionDisplay</td>
                    <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @m.Content
                    </td>
                    <td>@m.UsageCount</td>
                    <td>
                        <a href="/verwaltung/textbausteine/@m.Id/bearbeiten" class="btn-link">Bearbeiten</a>
                        <button class="btn-link" style="color:var(--color-danger,#dc2626)" @onclick="() => ConfirmDelete(m)">Loeschen</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (deleteTarget is not null)
{
    <div class="modal-overlay" @onclick="() => deleteTarget = null">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:400px">
            <h3>Textbaustein loeschen?</h3>
            <p>Moechten Sie den Textbaustein "<strong>@deleteTarget.Title</strong>" wirklich loeschen?</p>
            <div class="form-actions">
                <button class="btn btn-secondary" @onclick="() => deleteTarget = null">Abbrechen</button>
                <button class="btn btn-danger" @onclick="DeleteModule">Loeschen</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<TextModuleDto>? modules;
    private List<string> categories = [];
    private string selectedCategory = "";
    private string sortBy = "";
    private string statusMessage = "";
    private bool statusIsError;
    private TextModuleDto? deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadModules();
    }

    private async Task LoadModules()
    {
        modules = (await TextModuleService.GetAllAsync(
            string.IsNullOrEmpty(selectedCategory) ? null : selectedCategory,
            string.IsNullOrEmpty(sortBy) ? null : sortBy)).ToList();
        var allModules = await TextModuleService.GetAllAsync();
        categories = allModules.Select(m => m.Category)
            .Where(c => !string.IsNullOrEmpty(c))
            .Distinct().OrderBy(c => c).ToList();
    }

    private void ConfirmDelete(TextModuleDto m) => deleteTarget = m;

    private async Task DeleteModule()
    {
        if (deleteTarget is null) return;
        await TextModuleService.DeleteAsync(deleteTarget.Id);
        deleteTarget = null;
        await LoadModules();
    }

    private async Task ExportModules()
    {
        try
        {
            var data = await TextModuleService.ExportAsync(
                string.IsNullOrEmpty(selectedCategory) ? null : selectedCategory);
            var base64 = Convert.ToBase64String(data);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='textbausteine-export.json';document.body.appendChild(a);a.click();a.remove();");
            statusMessage = "Export erfolgreich heruntergeladen.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Export fehlgeschlagen: {ex.Message}";
            statusIsError = true;
        }
    }

    private async Task HandleImport(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file.Size > 1_000_000)
            {
                statusMessage = "Datei zu gross (max. 1 MB).";
                statusIsError = true;
                return;
            }

            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(1_000_000).CopyToAsync(ms);

            Guid creatorId = Guid.Empty;
            if (AuthState is not null)
            {
                var state = await AuthState;
                var userId = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (Guid.TryParse(userId, out var uid)) creatorId = uid;
            }

            var count = await TextModuleService.ImportAsync(ms.ToArray(), creatorId);
            statusMessage = $"{count} Textbaustein(e) importiert.";
            statusIsError = false;
            await LoadModules();
        }
        catch (Exception ex)
        {
            statusMessage = $"Import fehlgeschlagen: {ex.Message}";
            statusIsError = true;
        }
    }
}
